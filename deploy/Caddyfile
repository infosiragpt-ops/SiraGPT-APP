{
	email admin@siragpt.com

	# On-demand TLS for user-published custom domains. Caddy asks the backend
	# whether a domain is allowed a cert BEFORE issuing one — so only domains
	# that actually have a deployed site (under /srv/sites) ever get a cert.
	on_demand_tls {
		ask http://backend:5000/api/deployments/domain-allow
	}
}

# ── SiraGPT itself (explicit hosts — always matched before the catch-all
# below, so SiraGPT is never affected by user publishing) ──────────────
siragpt.com, www.siragpt.com, office.siragpt.com {
	encode zstd gzip

	handle /api/* {
		reverse_proxy backend:5000
	}

	handle /uploads/* {
		reverse_proxy backend:5000
	}

	handle {
		reverse_proxy frontend:3000
	}
}

api.siragpt.com {
	encode zstd gzip
	reverse_proxy backend:5000
}

# ── User-published custom domains (e.g. chatgpt66.com) ──────────────────
# Any domain NOT matched above. Auto HTTPS via on-demand TLS (gated by
# /api/deployments/domain-allow). Serves the deployed static site from
# /srv/sites/<host> — which maps to the host's /var/www/published-sites,
# a directory fully isolated from SiraGPT. If a domain has no deployed
# site yet, it falls back to the SiraGPT frontend (current behaviour).
https:// {
	tls {
		on_demand
	}
	encode zstd gzip

	handle /api/* {
		reverse_proxy backend:5000
	}

	handle /uploads/* {
		reverse_proxy backend:5000
	}

	handle {
		root * /srv/sites/{host}
		@published file /index.html
		handle @published {
			try_files {path} /index.html
			file_server
		}
		handle {
			reverse_proxy frontend:3000
		}
	}
}
