{
	email admin@siragpt.com

	# On-demand TLS for user-published custom domains. Caddy asks the backend
	# whether a domain is allowed a cert BEFORE issuing one — so only domains
	# that actually have a deployed site (under /srv/sites) ever get a cert.
	on_demand_tls {
		ask http://backend:5000/api/deployments/domain-allow
	}
}

# ── SiraGPT itself (explicit hosts — always matched before the catch-all
# below, so SiraGPT is never affected by user publishing) ──────────────
siragpt.com, www.siragpt.com, office.siragpt.com {
	encode zstd gzip

	handle /api/* {
		reverse_proxy backend:5000
	}

	handle /uploads/* {
		reverse_proxy backend:5000
	}

	handle {
		reverse_proxy frontend:3000
	}
}

api.siragpt.com {
	encode zstd gzip
	reverse_proxy backend:5000
}

# ── Codex live previews — SEPARATE origin (Replit-style isolation) ──────
# Generated apps run UNSANDBOXED inside an iframe on siragpt.com. Serving
# them from preview.siragpt.com gives each app the browser's own origin
# isolation: full module loading + localStorage for the app, zero access to
# siragpt.com cookies/storage/APIs. Only the tokenized preview proxy is
# exposed on this host — the token in the path is the sole credential, so
# nothing cookie-authenticated is reachable here. frame-ancestors lets the
# platform embed it; X-Frame-Options is dropped for the same reason.
preview.siragpt.com {
	encode zstd gzip

	@preview path /api/codex/projects/*/preview/*
	handle @preview {
		reverse_proxy backend:5000 {
			header_down -X-Frame-Options
			header_down Content-Security-Policy "frame-ancestors https://siragpt.com https://www.siragpt.com"
		}
	}
	handle {
		respond "Not found" 404
	}
}

# ── User-published full-stack Node apps (one site block per domain) ─────
# Each container deploy drops a <domain>.caddy snippet here (reverse_proxy to
# the app's container). These are EXPLICIT host matchers, so they win over the
# static https:// catch-all below — a Node-app domain bypasses /srv/sites.
# Safe: a malformed snippet is rejected by `caddy validate` before reload.
import /etc/caddy/apps/*.caddy

# ── User-published custom domains (e.g. chatgpt66.com) ──────────────────
# Any domain NOT matched above. Auto HTTPS via on-demand TLS (gated by
# /api/deployments/domain-allow). Serves the deployed static site from
# /srv/sites/<host> — which maps to the host's /var/www/published-sites,
# a directory fully isolated from SiraGPT. If a domain has no deployed
# site yet, it falls back to the SiraGPT frontend (current behaviour).
https:// {
	tls {
		on_demand
	}
	encode zstd gzip

	handle /api/* {
		reverse_proxy backend:5000
	}

	handle /uploads/* {
		reverse_proxy backend:5000
	}

	handle {
		root * /srv/sites/{host}
		@published file /index.html
		handle @published {
			try_files {path} /index.html
			file_server
		}
		handle {
			reverse_proxy frontend:3000
		}
	}
}
