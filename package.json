    "native:android:signing-fingerprint": "node scripts/verify-android-upload-certificate.js",
    "native:store:readiness": "node scripts/native-store-readiness.js",
    "native:store:assets": "node scripts/native-store-assets-readiness.js",
    "native:store:assets:generate": "node scripts/generate-native-store-assets.js",
