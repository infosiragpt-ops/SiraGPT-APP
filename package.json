{
  "name": "my-v0-project",
  "version": "0.4.4",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run build:backend && NEXT_OUTPUT=standalone NODE_ENV=production NEXT_TELEMETRY_DISABLED=1 NODE_OPTIONS=\"${NODE_OPTIONS:---max-old-space-size=4096}\" next build --no-lint && npm run postbuild:slim",
    "build:backend": "npm --prefix backend exec -- prisma generate --schema backend/prisma/schema.prisma",
    "postbuild:slim": "node scripts/postbuild-slim.js",
    "start": "node scripts/start-all.cjs",
    "start:next-only": "next start",
    "lint": "next lint --max-warnings 50",
    "lint:count": "next lint 2>&1 | grep -c 'Warning:' || true",
    "ui-lock:verify": "bash scripts/verify-ui-lock.sh",
    "ui-lock:update": "bash scripts/update-ui-lock.sh",
    "clean": "rm -rf .next .test-dist .playwright-cli output test-results",
    "clean:all": "npm run clean && rm -rf node_modules backend/node_modules",
    "pretest": "cd backend && npx prisma generate",
    "test": "rm -rf .test-dist && node ./node_modules/typescript/bin/tsc -p tests/tsconfig.json && node --test \".test-dist/tests/**/*.test.js\"",
    "test:unit": "NODE_ENV=test vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "test:all": "npm test && vitest run",
    "eval:mythos": "node scripts/run-mythos-preview-evals.js",
    "eval:mythos:json": "node scripts/run-mythos-preview-evals.js --json",
    "eval:understanding": "node backend/scripts/run-understanding-eval.js",
    "eval:understanding:json": "node backend/scripts/run-understanding-eval.js --json",
    "eval:intelligence": "node ./node_modules/typescript/bin/tsc -p tests/tsconfig.json && node .test-dist/server/intelligence/eval/run.js",
    "eval:intelligence:json": "node ./node_modules/typescript/bin/tsc -p tests/tsconfig.json && node .test-dist/server/intelligence/eval/run.js --json",
    "prepare": "husky",
    "mobile:sync": "cap sync",
    "mobile:open:android": "cap open android",
    "mobile:open:ios": "cap open ios",
    "mobile:doctor": "cap doctor",
    "mobile:add:android": "cap add android",
    "mobile:add:ios": "cap add ios",
    "mobile:dev:android": "CAPACITOR_SERVER_URL=http://10.0.2.2:3000 sh -c 'cap sync android && cap run android'",
    "mobile:dev:ios": "CAPACITOR_SERVER_URL=http://localhost:3000 sh -c 'cap sync ios && cap run ios'",
    "mobile:release:android": "sh scripts/build-android-release.sh",
    "native:version:sync": "node scripts/sync-native-version.js",
    "native:version:check": "node scripts/sync-native-version.js --check",
    "native:readiness": "node scripts/native-release-readiness.js",
    "native:readiness:android": "node scripts/native-release-readiness.js --require=android",
    "native:readiness:ios": "node scripts/native-release-readiness.js --require=ios",
    "native:readiness:mobile": "node scripts/native-release-readiness.js --require=mobile",
    "native:readiness:desktop": "node scripts/native-release-readiness.js --require=desktop",
    "native:readiness:all": "node scripts/native-release-readiness.js --require=all",
