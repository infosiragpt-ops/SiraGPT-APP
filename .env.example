# ─── siraGPT Environment Variables ──────────────────────────
# Copy this to .env and fill in your keys.
# `docker compose up` reads this file automatically.
#
# ⚠️  NEVER commit .env to git. This file (.env.example) is the
#     template — create a copy without the .example suffix.
#
# 🔐  Generate strong secrets:
#        ./scripts/generate-secrets.sh
#
# 📖  Full reference: docs/operations/ENVIRONMENT.md
# ─────────────────────────────────────────────────────────────

# ── PostgreSQL ──
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=siragpt

# ── Backend ──
PORT=5000
NODE_ENV=development
PRISMA_DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# ⚠️  CHANGE THESE — use `./scripts/generate-secrets.sh` or:
#        node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string
SESSION_SECRET=change-this-too

CORS_ORIGINS=http://localhost:3000
REDIS_URL=redis://redis:6379
AGENT_TASK_BOOT_RECOVERY_DISABLED=false
AGENT_TASK_BOOT_RECOVERY_STALE_MS=60000
MAX_FILE_SIZE=50
UPLOAD_DIR=uploads
SIRAGPT_XLSX_MAX_SHEETS=5
SIRAGPT_XLSX_DEFANG_FORMULAS=true
SIRAGPT_REDACT_EXTRA_HEADERS=
SIRAGPT_REDACT_EXTRA_QUERY_KEYS=

# ── LLM API Keys (paid tiers) ──
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
GOOGLE_AI_API_KEY=
# Cerebras = "Free IA" (Llama 3.1 8B). Required for the free-tier
# fallback to work; without it /api/free-ia/status returns enabled:false
# and credit-exhausted requests will 402 instead of degrading silently.
# Sign-up (free tier available): https://cloud.cerebras.ai/
CEREBRAS_API_KEY=
MISTRAL_API_KEY=
DEEPSEEK_API_KEY=
# Free IA (Cerebras Llama 3.1 8B) — used as the free-tier model and as
# the automatic fallback when premium credits are exhausted. Defaults
# resolve to llama-3.1-8b / Cerebras / "Free IA" when these vars are
# unset; override here per environment. Legacy GEMA4_* aliases below
# still win for backwards compatibility with existing deployments.
FREE_IA_MODEL_ID=llama-3.1-8b
FREE_IA_DISPLAY_NAME=Free IA
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
GEMA4_MODEL_ID=
GEMA4_PROVIDER=
GEMA4_DISPLAY_NAME=
GEMA4_ICON=CerebrasLogo

# ── Paraphrase tunables ──
# Per-request text-length cap on POST /api/paraphrase. Default 20_000
# chars, hard upper bound 100_000. Invalid/non-numeric values fall back
# to the default.
PARAPHRASE_MAX_TEXT_LENGTH=20000
# Credit ratio per 1000 chars of paraphrase input. Default 1.
CREDITS_PARAPHRASE_PER_1K_CHARS=1

# ── Auth (Google OAuth) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_CALENDAR_DRIVE_URI=http://localhost:5000/api/auth/google-services/callback
GOOGLE_AUTH_URI=http://localhost:5000/api/auth/google/callback

# ── Spotify ──
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:5000/api/spotify/callback

# ── Payments ──
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_PRO_MAX=
STRIPE_PRICE_ENTERPRISE=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox
MERCADOPAGO_ACCESS_TOKEN=

# ── SMTP (Email) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── Frontend ──
NEXT_PUBLIC_API_URL=http://localhost:5000/api
NEXT_PUBLIC_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=siraGPT
NEXT_PUBLIC_APP_DESCRIPTION=Multi-LLM AI Platform
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── Scientific paper search APIs (free; no key required for arXiv, OpenAlex, CrossRef, Europe PMC) ──
SIRAGPT_RESEARCH_EMAIL=
SEMANTIC_SCHOLAR_API_KEY=
NCBI_API_KEY=
CORE_API_KEY=
RESEARCH_VISION_MODEL=gpt-4o-mini

# ── Orchestration: LLM Gateway ──
SIRAGPT_LLM_GATEWAY_TIMEOUT_MS=45000
SIRAGPT_LLM_GATEWAY_BREAKER_RESET_MS=60000
SIRAGPT_LLM_MAX_TOKENS=4096

# ── Orchestration: Semantic LLM Cache (Upstash Redis REST) ──
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
SIRAGPT_CACHE_TTL_DEFAULT_SECONDS=3600
SIRAGPT_CACHE_TTL_CODE=1800
SIRAGPT_CACHE_TTL_SPEED=600

# ── Orchestration: Document Pipeline ──
SIRAGPT_SEMANTIC_CHUNK_SIZE=1200
SIRAGPT_SEMANTIC_CHUNK_OVERLAP=200

# ── Memory: pgvector embeddings ──
VOYAGE_API_KEY=
JINA_API_KEY=
SIRAGPT_USER_MEMORY_STORE=pgvector
SIRAGPT_MEMORY_EMBED_PROVIDER=voyage
SIRAGPT_MEMORY_EMBED_MODEL=voyage-3-large
SIRAGPT_MEMORY_MAX_PER_USER=500
SIRAGPT_MEMORY_PROMOTE_THRESHOLD=0.8
SIRAGPT_MEMORY_DEMOTE_THRESHOLD=0.3

# ── Multi-Agent ──
SIRAGPT_MULTI_AGENT_FRAMEWORK=builtin

# ── Web Search Tools ──
TAVILY_API_KEY=
EXA_API_KEY=
FIRECRAWL_API_KEY=

# ── Observability: Langfuse ──
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_SAMPLE_RATE=1.0

# ── Observability: Sentry ──
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Storage: Cloudflare R2 ──
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=siragpt-artifacts
R2_ENDPOINT=
R2_PRESIGNED_URL_TTL_SECONDS=900

# ── Multichannel: OpenClaw (optional) ──
OPENCLAW_ENABLED=false
OPENCLAW_GATEWAY_URL=http://localhost:8787
OPENCLAW_API_KEY=
OPENCLAW_CHANNELS=whatsapp,telegram,slack,discord,signal,imessage
SIRAGPT_INTERNAL_API_URL=http://localhost:5000
SIRAGPT_INTERNAL_API_KEY=

# ── Telegram dev-agent control (optional) ──
# Get a token from @BotFather. The whole feature is inert until this is set.
TELEGRAM_BOT_TOKEN=
# Random string; sent by Telegram as the X-Telegram-Bot-Api-Secret-Token header.
TELEGRAM_WEBHOOK_SECRET=
# Public HTTPS URL of POST /api/telegram/webhook (used to auto-register on boot).
TELEGRAM_WEBHOOK_URL=
# siraGPT user id the bot runs codex runs as (your account id).
TELEGRAM_AGENT_USER_ID=
# Optional CSV of allowed Telegram chat ids; empty = open to anyone who has the bot.
TELEGRAM_ALLOWED_CHAT_IDS=
