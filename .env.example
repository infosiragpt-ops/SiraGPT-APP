# ─── siraGPT Environment Variables ──────────────────────────
# Copy this to .env and fill in your keys.
# `docker compose up` reads this file automatically.
#
# ⚠️  NEVER commit .env to git. This file (.env.example) is the
#     template — create a copy without the .example suffix.
#
# 🔐  Generate strong secrets:
#        ./scripts/generate-secrets.sh
#
# 📖  Full reference: docs/operations/ENVIRONMENT.md
# ─────────────────────────────────────────────────────────────

# ── PostgreSQL ──
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=siragpt

# ── Backend ──
PORT=5000
# Use the literal value "production" for production. The alias "prod" is
# rejected at startup so every security policy sees one canonical mode.
NODE_ENV=development
# Explicit RBAC rollout mode. Production should use enforce; shadow preserves
# legacy admin booleans only while assignments are being verified/backfilled.
RBAC_ENFORCEMENT_MODE=shadow
RBAC_CACHE_TTL_MS=60000
RBAC_MUTATION_LOCK_TIMEOUT_MS=500
# Enforce-mode local fallback is always capped at 5000ms. Redis connection and
# subscription startup are bounded so an unavailable cache never blocks boot.
RBAC_REDIS_CONNECT_TIMEOUT_MS=500
RBAC_REDIS_STARTUP_TIMEOUT_MS=500
RBAC_REDIS_COMMAND_TIMEOUT_MS=500
# Authentication deletion-race controls. Redis revocation is an acceleration
# path; persisted-session heartbeat checks remain authoritative when unavailable.
AUTH_USER_LOCK_TIMEOUT_MS=500
AUTH_REVOCATION_REDIS_CONNECT_TIMEOUT_MS=500
AUTH_REVOCATION_REDIS_COMMAND_TIMEOUT_MS=500
AUTH_SOCKET_REVALIDATION_CACHE_TTL_MS=5000
AUTH_SOCKET_REVALIDATION_TIMEOUT_MS=2000
AUTH_SOCKET_REVALIDATION_CACHE_MAX=2000
# Single-container parent grace period after SIGTERM/SIGINT. Defaults to 50000ms
# and is clamped to 40000-120000ms so the backend's 30s shutdown can complete.
# Windows uses IPC for graceful backend drain; forced process-tree kill is
# reserved for this deadline.
SIRAGPT_PARENT_SHUTDOWN_TIMEOUT_MS=50000
# Per-workspace dev-runner grace before escalation to process-tree SIGKILL.
SIRAGPT_WORKSPACE_RUN_STOP_GRACE_MS=3000
# Runtime datasource. May be direct PostgreSQL or prisma+postgres (Accelerate).
PRISMA_DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
# Direct PostgreSQL datasource used only by migrations, pg preflight, and the
# advisory lock. Required when the runtime URL is remote.
DIRECT_DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
# Legacy compatibility fallback. Leave empty for the explicit two-role setup.
DATABASE_URL=
# TLS certificate verification is enabled whenever the direct connection uses
# TLS. Only the exact value "false" disables verification. CA/CERT/KEY values
# accept inline PEM or a path to a PEM file; environment values override URL
# sslrootcert/sslcert/sslkey values.
DATABASE_SSL_REJECT_UNAUTHORIZED=true
DATABASE_SSL_CA=
DATABASE_SSL_CERT=
DATABASE_SSL_KEY=
# Hard deadlines for Prisma CLI and boot-time pg work.
MIGRATION_COMMAND_TIMEOUT_MS=300000
# Hard deadline for auxiliary boot commands such as stale-port cleanup.
BOOT_COMMAND_TIMEOUT_MS=5000
MIGRATION_DB_CONNECT_TIMEOUT_MS=10000
MIGRATION_DB_QUERY_TIMEOUT_MS=15000
MIGRATION_DB_STATEMENT_TIMEOUT_MS=15000
MIGRATION_LOCK_TIMEOUT_MS=120000
# U0 reviewed one-off only (deploy-production-baseline-* / baseline-migration-history.js).
# Never set on normal boot. Exact phrase required: I_REVIEWED_PRODUCTION_SCHEMA
# MIGRATION_BASELINE_CONFIRM=
# MIGRATION_BASELINE_DRY_RUN=0
# Local normal boot only. Release --migrate-only rejects a value of 1.
SKIP_MIGRATIONS=0
# Normal server boot may opt into degraded startup after a non-configuration
# migration failure. The --migrate-only release path always remains strict.
MIGRATION_NONFATAL=0
# Prisma v6 pool controls. Timeout is configured in milliseconds here and
# rounded up to whole `pool_timeout` seconds in the datasource URL.
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_POOL_TIMEOUT_MS=10000
# Advisory-only autoscaler: publishes a recommended limit but never replaces
# or resizes the live Prisma client.
DATABASE_POOL_AUTOSCALE_ENABLED=false
DATABASE_POOL_AUTOSCALE_INTERVAL_MS=30000
DATABASE_POOL_AUTOSCALE_MIN=2
DATABASE_POOL_AUTOSCALE_MAX=50
DATABASE_POOL_AUTOSCALE_COLD_SAMPLES=3

# ⚠️  CHANGE THESE — use `./scripts/generate-secrets.sh` or:
#        node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string
SESSION_SECRET=change-this-too
# Rolling-safe session-token migration. Keep compat while any old replica can
# run. After the compat release is fully drained, set both values to hash/1.
SESSION_TOKEN_HASH_MODE=compat
SESSION_TOKEN_HASH_COMPAT_DRAINED=0
# Hash activation converts plaintext rows in bounded transactions. Readiness
# remains blocked and continues the next batch on later probes.
SESSION_TOKEN_HASH_BACKFILL_BATCH_SIZE=100
SESSION_TOKEN_HASH_BACKFILL_MAX_BATCHES=10

# Direct/local Compose publishes the backend without a trusted reverse proxy.
# Use TRUST_PROXY_CIDR instead only when the exact proxy network is known; never
# set both variables.
TRUST_PROXY_HOPS=0
TRUST_PROXY_CIDR=
CORS_ORIGINS=http://localhost:3000
CSRF_DISABLED=0
CSRF_PEPPER=
REDIS_URL=redis://redis:6379
# Production readiness requires Redis noeviction, Lua support, and memory below
# this bounded utilization ratio.
AUTH_SECURITY_REDIS_MAX_MEMORY_RATIO=0.8
# Readiness retries failed auth-security Redis probes with bounded backoff.
AUTH_SECURITY_READY_RETRY_BASE_MS=250
AUTH_SECURITY_READY_RETRY_MAX_MS=5000
# OAuth authorization state is signed and stored once in Redis. Production
# fails closed; development/test may use the bounded local fallback.
OAUTH_STATE_TTL=10m
OAUTH_STATE_RETRY_AFTER_SECONDS=5
OAUTH_STATE_CACHE_MAX_ENTRIES=10000
OAUTH_STATE_REDIS_CONNECT_TIMEOUT_MS=500
OAUTH_STATE_REDIS_COMMAND_TIMEOUT_MS=500
OAUTH_STATE_REDIS_PREFIX=sira:oauth-state:
# Super-admin impersonation uses atomic admin+target and global-admin windows.
IMPERSONATION_TARGET_LIMIT=3
IMPERSONATION_ADMIN_LIMIT=10
IMPERSONATION_WINDOW_MS=3600000
IMPERSONATION_MEMORY_MAX_KEYS=10000
IMPERSONATION_REDIS_CONNECT_TIMEOUT_MS=500
IMPERSONATION_REDIS_COMMAND_TIMEOUT_MS=500
IMPERSONATION_REDIS_PREFIX=sira:impersonation:
IMPERSONATION_STORE_RETRY_AFTER_SECONDS=5
# SP-initiated SAML request/RelayState storage. Production requires Redis and
# fails closed; bounded memory is used only outside production. Leave the
# dedicated secret empty to derive it from JWT_SECRET.
SAML_REQUEST_TTL_MS=300000
SAML_REQUEST_CACHE_MAX_ENTRIES=5000
SAML_REDIS_CONNECT_TIMEOUT_MS=500
SAML_REDIS_COMMAND_TIMEOUT_MS=500
SAML_REDIS_RETRY_BASE_MS=100
SAML_REDIS_RETRY_MAX_MS=5000
SAML_REDIS_PREFIX=sira:saml:
SAML_RELAY_STATE_SECRET=
# Exact SAML ACS ingress: distributed pre-parser limiter plus a 256 KiB
# URL-encoded body cap (configurable only within the safe 64-512 KiB range).
SAML_ACS_BODY_LIMIT_BYTES=262144
SAML_ACS_RATE_LIMIT_MAX=30
SAML_ACS_RATE_LIMIT_WINDOW_MS=60000
# Sensitive auth, API-key, and billing limiters use Redis and fail closed in
# production. `memory` and `fail-open` are accepted only outside production.
RATE_LIMIT_STORE=redis
RATE_LIMIT_SENSITIVE_POLICY=distributed
RATE_LIMIT_REDIS_COMMAND_TIMEOUT_MS=1000
RATE_LIMIT_STORE_RETRY_AFTER_SECONDS=5
RATE_LIMIT_BILLING_CHECKOUT_MAX=10
RATE_LIMIT_BILLING_CHECKOUT_IP_MAX=100
RATE_LIMIT_BILLING_VERIFY_MAX=20
RATE_LIMIT_BILLING_VERIFY_IP_MAX=200
RATE_LIMIT_BILLING_PLAN_CHANGE_MAX=5
RATE_LIMIT_BILLING_PLAN_CHANGE_IP_MAX=50
RATE_LIMIT_BILLING_WINDOW_MS=900000
RATE_LIMIT_BILLING_PLAN_WINDOW_MS=3600000
RATE_LIMIT_BILLING_REFUND_MAX=5
RATE_LIMIT_BILLING_REFUND_IP_MAX=50
RATE_LIMIT_BILLING_REFUND_WINDOW_MS=3600000
SIRAGPT_API_KEY_AUDIT_COUNTER_MAX=10000
AGENT_TASK_BOOT_RECOVERY_DISABLED=false
AGENT_TASK_BOOT_RECOVERY_STALE_MS=60000
MAX_FILE_SIZE=50
MAX_UPLOAD_FILES=400
SIRAGPT_MAX_SIMULTANEOUS_DOCUMENTS=400
NEXT_PUBLIC_COMPOSER_MAX_FILES=400
UPLOAD_DIR=uploads
SIRAGPT_XLSX_MAX_SHEETS=5
SIRAGPT_XLSX_DEFANG_FORMULAS=true
SIRAGPT_REDACT_EXTRA_HEADERS=
SIRAGPT_REDACT_EXTRA_QUERY_KEYS=

# ── LLM API Keys (paid tiers) ──
OPENROUTER_API_KEY=
XAI_API_KEY=
GROK_VOICE_MODEL=grok-4.3
GROK_VOICE_STT_MODEL=grok-stt
GROK_VOICE_TTS_VOICE=eve
GROK_VOICE_TTS_LANGUAGE=es
GROK_VOICE_TTS_FORMAT=mp3
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
GOOGLE_AI_API_KEY=
# ── Video generation (Fal.ai / Veo Fast) ──
# Preferred key for /api/ai/generate-video. FAL_KEY and TAL_AI_API_KEY are
# accepted as local aliases for existing developer machines.
FAL_API_KEY=
FAL_KEY=
TAL_AI_API_KEY=
# Cerebras = "Free IA" (Llama 3.1 8B). Required for the free-tier
# fallback to work; without it /api/free-ia/status returns enabled:false
# and credit-exhausted requests will 402 instead of degrading silently.
# Sign-up (free tier available): https://cloud.cerebras.ai/
CEREBRAS_API_KEY=
MISTRAL_API_KEY=
DEEPSEEK_API_KEY=
# Free IA (Cerebras Llama 3.1 8B) — used as the free-tier model and as
# the automatic fallback when premium credits are exhausted. Defaults
# resolve to llama-3.1-8b / Cerebras / "Free IA" when these vars are
# unset; override here per environment. Legacy GEMA4_* aliases below
# still win for backwards compatibility with existing deployments.
FREE_IA_MODEL_ID=llama-3.1-8b
FREE_IA_DISPLAY_NAME=Free IA
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
GEMA4_MODEL_ID=
GEMA4_PROVIDER=
GEMA4_DISPLAY_NAME=
GEMA4_ICON=CerebrasLogo

# ── Paraphrase tunables ──
# Per-request text-length cap on POST /api/paraphrase. Default 20_000
# chars, hard upper bound 100_000. Invalid/non-numeric values fall back
# to the default.
PARAPHRASE_MAX_TEXT_LENGTH=20000
# Credit ratio per 1000 chars of paraphrase input. Default 1.
CREDITS_PARAPHRASE_PER_1K_CHARS=1

# ── Auth (Google OAuth) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_AUTH_BASE_URL=http://localhost:5000
GOOGLE_AUTH_URI=http://localhost:5000/api/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/gmail/callback
GOOGLE_REDIRECT_CALENDAR_DRIVE_URI=http://localhost:5000/api/auth/google-services/callback

# Optional comma-separated exact origins for intentional cross-origin browser
# handoffs after OAuth. Production always trusts the configured frontend
# origins; this extension is capped at 10 HTTPS origins / 2048 characters.
OAUTH_POST_CALLBACK_ALLOWED_ORIGINS=

# ── GitHub OAuth ──
GITHUB_OAUTH_REDIRECT_URI=http://localhost:5000/api/github/callback
GITHUB_OAUTH_SUCCESS_REDIRECT=http://localhost:3000/settings

# ── Spotify ──
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:5000/api/spotify/callback
SPOTIFY_OAUTH_SUCCESS_REDIRECT=http://localhost:3000/chat
SPOTIFY_OAUTH_FAILURE_REDIRECT=http://localhost:3000/connections

# ── Payments ──
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Optional remote snapshot hydration; local webhook handling is deterministic by default.
STRIPE_WEBHOOK_RETRIEVE_SUBSCRIPTION_STATE=false
STRIPE_WEBHOOK_RECOVERY_DISABLED=false
STRIPE_WEBHOOK_RECOVERY_INTERVAL_MS=60000
STRIPE_WEBHOOK_RECOVERY_BATCH_SIZE=25
STRIPE_WEBHOOK_RECOVERY_LEASE_MS=120000
STRIPE_WEBHOOK_RECOVERY_BACKOFF_BASE_MS=30000
STRIPE_WEBHOOK_RECOVERY_BACKOFF_MAX_MS=3600000
STRIPE_WEBHOOK_RECOVERY_MAX_ATTEMPTS=8
STRIPE_PRICE_PRO=
STRIPE_PRICE_PRO_MAX=
STRIPE_PRICE_ENTERPRISE=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox
MERCADOPAGO_ACCESS_TOKEN=

# ── SMTP (Email) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── Frontend ──
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:5000/api
NEXT_PUBLIC_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=siraGPT
NEXT_PUBLIC_APP_DESCRIPTION=Multi-LLM AI Platform
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── Scientific paper search APIs (free; no key required for arXiv, OpenAlex, CrossRef, Europe PMC) ──
SIRAGPT_RESEARCH_EMAIL=
SEMANTIC_SCHOLAR_API_KEY=
NCBI_API_KEY=
CORE_API_KEY=
RESEARCH_VISION_MODEL=gpt-4o-mini

# ── Orchestration: LLM Gateway ──
SIRAGPT_LLM_GATEWAY_TIMEOUT_MS=45000
SIRAGPT_LLM_GATEWAY_BREAKER_RESET_MS=60000
SIRAGPT_LLM_MAX_TOKENS=4096

# ── Orchestration: Semantic LLM Cache (Upstash Redis REST) ──
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
SIRAGPT_CACHE_TTL_DEFAULT_SECONDS=3600
SIRAGPT_CACHE_TTL_CODE=1800
SIRAGPT_CACHE_TTL_SPEED=600

# ── Orchestration: Document Pipeline ──
SIRAGPT_SEMANTIC_CHUNK_SIZE=1200
SIRAGPT_SEMANTIC_CHUNK_OVERLAP=200

# ── Memory: pgvector embeddings ──
VOYAGE_API_KEY=
JINA_API_KEY=
SIRAGPT_USER_MEMORY_STORE=pgvector
SIRAGPT_MEMORY_EMBED_PROVIDER=voyage
SIRAGPT_MEMORY_EMBED_MODEL=voyage-3-large
SIRAGPT_MEMORY_MAX_PER_USER=500
SIRAGPT_MEMORY_PROMOTE_THRESHOLD=0.8
SIRAGPT_MEMORY_DEMOTE_THRESHOLD=0.3

# ── Multi-Agent ──
SIRAGPT_MULTI_AGENT_FRAMEWORK=builtin

# ── External MCP servers ──
# Production MCP uses a comma-separated HTTPS hostname allowlist. Exact hosts
# and safe leading-* subdomain patterns are supported (for example,
# mcp.example.com,*.tools.example.com). Empty means MCP deny-all/degraded.
SIRAGPT_MCP_ALLOWED_HOSTS=
# Local development only: permit http://localhost / 127.0.0.1 MCP endpoints.
SIRAGPT_MCP_ALLOW_HTTP=0

# ── Web Search Tools ──
TAVILY_API_KEY=
EXA_API_KEY=
FIRECRAWL_API_KEY=

# ── Observability: Langfuse ──
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_SAMPLE_RATE=1.0

# ── Observability: Sentry ──
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Storage: Cloudflare R2 ──
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=siragpt-artifacts
R2_ENDPOINT=
R2_PRESIGNED_URL_TTL_SECONDS=900

# ── Multichannel: OpenClaw (optional) ──
OPENCLAW_ENABLED=false
OPENCLAW_GATEWAY_URL=http://localhost:8787
OPENCLAW_API_KEY=
OPENCLAW_CHANNELS=whatsapp,telegram,slack,discord,signal,imessage
SIRAGPT_INTERNAL_API_URL=http://localhost:5000
SIRAGPT_INTERNAL_API_KEY=

# ── Telegram dev-agent control (optional) ──
# Get a token from @BotFather. The whole feature is inert until this is set.
TELEGRAM_BOT_TOKEN=
# Random string; sent by Telegram as the X-Telegram-Bot-Api-Secret-Token header.
TELEGRAM_WEBHOOK_SECRET=
# Public HTTPS URL of POST /api/telegram/webhook (used to auto-register on boot).
TELEGRAM_WEBHOOK_URL=
# siraGPT user id the bot runs codex runs as (your account id).
TELEGRAM_AGENT_USER_ID=
# Optional CSV of allowed Telegram chat ids; empty = open to anyone who has the bot.
TELEGRAM_ALLOWED_CHAT_IDS=

# ── OpenCode engine (Bun sidecar) — vendor/opencode ─────────
# Set to http://opencode:4096 and run `docker compose --profile opencode up`
OPENCODE_SERVER_URL=
# Optional HTTP basic password protecting the engine server
OPENCODE_SERVER_PASSWORD=
# Engine also uses ANTHROPIC_API_KEY / OPENAI_API_KEY / OPENROUTER_API_KEY / GEMINI_API_KEY (above)

# ── /code execution plane ─────────────────────────────────────
# Long random service credential shared ONLY by backend and runner. Required in
# production; generate with: openssl rand -base64 48
CODE_RUNNER_CONTROL_TOKEN=
# The current Bun sidecar is an interim shared container and must stay canary-
# only. Public access is accepted only for a real isolated provider.
CODEX_SANDBOX_PROVIDER=shared-runner
# Optional per-workspace gVisor provider foundation. It remains disabled and
# non-public until its file, preview, egress, quota and secret-ref gates land.
# Production's PM2 backend reaches the profile-gated controller only through
# its loopback publish; the Docker-backend profile overrides this URL with the
# internal service DNS name.
CODEX_RUNSC_SANDBOX_ENABLED=false
CODEX_RUNSC_CONTROLLER_URL=http://127.0.0.1:4098
# Long independent secrets; do not reuse the runner token or database vault.
# The controller token is consumed by both the PM2 backend and controller.
RUNSC_SANDBOX_CONTROLLER_TOKEN=
CODEX_RUNSC_WORKSPACE_KEY=
RUNSC_SANDBOX_EXEC_TIMEOUT_MS=600000
# Immutable local image id produced by `docker image inspect`, never a tag.
RUNSC_SANDBOX_WORKER_IMAGE=
# Legacy/informational label. Security decisions use the provider's validated
# boot attestation, never this operator-controlled string.
CODEX_RUNNER_ISOLATION_MODE=shared-container
CODEX_AGENT_OPEN_TO_ALL=false
CODEX_AGENT_ALLOWED_USER_IDS=
# AgentAdapter v1 implementer. Unknown ids fail closed; only native is
# registered until version-pinned external workers pass staging gates.
CODEX_IMPLEMENTER_ADAPTER=native
# Writers share one checkout in the interim runner. Enable only after each
# parallel agent receives its own isolated Git worktree.
CODEX_PARALLEL_WRITE_SUBAGENTS=false
# Additive project-database foundation. Keep disabled until every run uses an
# attested isolated sandbox and an application PostgreSQL cluster separate
# from SiraGPT's control database.
CODEX_PROJECT_DATABASES=false
# Required only when the feature is deliberately enabled. JSON object mapping
# key ids to exact 32-byte keys (64-char hex, base64:<value>, or base64url).
CODEX_DATABASE_VAULT_ACTIVE_KEY_ID=
CODEX_DATABASE_VAULT_KEYS=
# Legacy in-API runner executes untrusted npm/shell on the backend host. Keep it
# disabled; the deliberately loud unsafe acknowledgement is undocumented here.
CODE_HOST_RUNNER=false
