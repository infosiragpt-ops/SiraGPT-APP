{
  "name": "@siragpt/agents",
  "version": "0.1.0",
  "description": "Official TypeScript SDK for the SiraGPT Agents API.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "engines": { "node": ">=18" },
  "keywords": ["siragpt", "agents", "ai", "sdk"],
  "publishConfig": { "access": "public" }
}