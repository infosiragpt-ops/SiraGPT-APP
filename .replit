modules = ["nodejs-20", "postgresql-16"]

# Default `Run` button: starts the Next.js dev server on Replit's
# external port (mapped from localhost:3000 below). The backend
# Express app is expected to run elsewhere (Railway/Fly/Render in
# production); locally the frontend talks to it via
# NEXT_PUBLIC_API_URL.
run = "ALLOW_REPLIT_PREVIEW=1 npm run dev -- -H 0.0.0.0 -p 3000"
entrypoint = "package.json"
hidden = [".next", "node_modules", ".test-dist", ".playwright-cli", "output", "test-results"]

[nix]
channel = "stable-25_05"

[deployment]
deploymentTarget = "autoscale"
build = ["npm", "run", "build"]
run = ["npm", "start"]

[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5050
externalPort = 3000

[gitHubImport]
requiredFiles = [".replit", "replit.nix", "package.json"]

[languages.typescript]
pattern = "**/{*.ts,*.tsx}"
syntax = "typescript"

[unitTest]
language = "nodejs"

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Backend"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && PORT=5050 node -r dotenv/config index.js dotenv_config_path=../.env.local"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "ALLOW_REPLIT_PREVIEW=1 npm run dev -- -H 0.0.0.0 -p 5000"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[userenv]

[userenv.production]
GOOGLE_AUTH_BASE_URL = "https://siragpt.com"
