modules = ["nodejs-22", "python-3.11", "postgresql-16"]

# Replit editor preview: Next.js dev server must listen on 0.0.0.0:3000.
run = "ALLOW_REPLIT_PREVIEW=1 npm run dev -- -H 0.0.0.0 -p 3000"
entrypoint = "package.json"
hidden = [".next", "node_modules", ".test-dist", ".playwright-cli", "output", "test-results"]

[nix]
channel = "stable-25_05"

[deployment]
deploymentTarget = "gce"
# Replit reuses the workspace across deploys. A stale @next/swc-* directory can
# make npm fail before build with ENOTEMPTY while renaming the platform SWC
# binary. Always start from a clean workspace and use npm ci so installs match
# package-lock.json exactly.
build = "rm -rf node_modules backend/node_modules .next && NEXT_PUBLIC_API_URL=/api BACKEND_INTERNAL_URL=http://localhost:5050 REPLIT_BACKEND_MODE=sidecar BACKEND_PORT=5050 FRONTEND_PORT=3000 HUSKY=0 npm ci && NEXT_PUBLIC_API_URL=/api BACKEND_INTERNAL_URL=http://localhost:5050 REPLIT_BACKEND_MODE=sidecar BACKEND_PORT=5050 FRONTEND_PORT=3000 HUSKY=0 npm --prefix backend ci && NEXT_PUBLIC_API_URL=/api BACKEND_INTERNAL_URL=http://localhost:5050 REPLIT_BACKEND_MODE=sidecar BACKEND_PORT=5050 FRONTEND_PORT=3000 REPLIT_DEPLOYMENT=1 npm run build"
run = "NEXT_PUBLIC_API_URL=/api BACKEND_INTERNAL_URL=http://localhost:5050 REPLIT_BACKEND_MODE=sidecar BACKEND_PORT=5050 FRONTEND_PORT=3000 REPLIT_DEPLOYMENT=1 npm start"

[packager.features]
# The deployment build command above owns installation. Disabling hosting's
# automatic npm install avoids the pre-build package phase that hit ENOTEMPTY.
enabledForHosting = false

[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 5050
externalPort = 3000

[gitHubImport]
requiredFiles = [".replit", "replit.nix", "package.json"]

[languages.typescript]
pattern = "**/{*.ts,*.tsx}"
syntax = "typescript"

[unitTest]
language = "nodejs"

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "oauth-url-smoke"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "SiraGPT Video"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "NEXT_PUBLIC_API_URL=/api BACKEND_INTERNAL_URL=http://localhost:5050 REPLIT_BACKEND_MODE=sidecar BACKEND_PORT=5050 FRONTEND_PORT=3000 NODE_ENV=development node -e \"const { spawn } = require('child_process'); const env = process.env; const backend = spawn('node', ['backend/scripts/start-with-migrations.js'], { cwd: '.', env: { ...env, PORT: '5050', HOST: '127.0.0.1', NODE_ENV: 'production' }, stdio: 'inherit' }); const frontend = spawn('npx', ['next', 'dev', '-p', '3000', '-H', '0.0.0.0'], { env: { ...env, PORT: '3000' }, stdio: 'inherit' });\""
waitForPort = 3000

[[workflows.workflow]]
name = "oauth-url-smoke"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && node --test tests/oauth-url-policy.test.js"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "SiraGPT Video"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5000 BASE_PATH=/sira-promo/ pnpm --filter @workspace/sira-promo run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[userenv]

[userenv.production]
GOOGLE_AUTH_BASE_URL = "https://siragpt.com"
GOOGLE_ALLOW_FRONTEND_CALLBACK = "true"

[userenv.shared]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000
