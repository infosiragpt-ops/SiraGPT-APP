modules = ["nodejs-22", "python-3.11"]

# Replit editor preview: Next.js dev server must listen on 0.0.0.0:3000.
run = "ALLOW_REPLIT_PREVIEW=1 npm run dev -- -H 0.0.0.0 -p 3000"
entrypoint = "package.json"
hidden = [".next", "node_modules", ".test-dist", ".playwright-cli", "output", "test-results"]

[nix]
channel = "stable-25_05"

[deployment]
deploymentTarget = "autoscale"
# Clean any node_modules / .next persisted from a prior build before installing.
# Replit reuses the workspace across deploys, and a stale @next/swc-* dir makes
# `npm install` fail with `ENOTEMPTY: rename …/@next/swc-linux-x64-musl` (exit 217).
# A clean slate makes the platform-specific SWC binaries extract reliably.
build = "rm -rf node_modules backend/node_modules .next && NEXT_PUBLIC_API_URL=/api BACKEND_INTERNAL_URL=https://api.siragpt.com REPLIT_BACKEND_MODE=external HUSKY=0 npm install && NEXT_PUBLIC_API_URL=/api BACKEND_INTERNAL_URL=https://api.siragpt.com REPLIT_BACKEND_MODE=external HUSKY=0 npm --prefix backend install && NEXT_PUBLIC_API_URL=/api BACKEND_INTERNAL_URL=https://api.siragpt.com REPLIT_BACKEND_MODE=external REPLIT_DEPLOYMENT=1 npm run build"
run = "NEXT_PUBLIC_API_URL=/api BACKEND_INTERNAL_URL=https://api.siragpt.com REPLIT_BACKEND_MODE=external REPLIT_DEPLOYMENT=1 npm start"

[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 5050
externalPort = 3000

[gitHubImport]
requiredFiles = [".replit", "replit.nix", "package.json"]

[languages.typescript]
pattern = "**/{*.ts,*.tsx}"
syntax = "typescript"

[unitTest]
language = "nodejs"

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "NEXT_PUBLIC_API_URL=/api BACKEND_INTERNAL_URL=http://localhost:5050 REPLIT_BACKEND_MODE=sidecar BACKEND_PORT=5050 FRONTEND_PORT=3000 NODE_ENV=development node -e \"const { spawn } = require('child_process'); const env = process.env; const backend = spawn('node', ['backend/scripts/start-with-migrations.js'], { cwd: '.', env: { ...env, PORT: '5050', HOST: '127.0.0.1', NODE_ENV: 'production' }, stdio: 'inherit' }); const frontend = spawn('npx', ['next', 'dev', '-p', '3000', '-H', '0.0.0.0'], { env: { ...env, PORT: '3000' }, stdio: 'inherit' });\""
waitForPort = 3000
