# ──────────────────────────────────────────────────────────────
# siraGPT — Backend (Express + Prisma)
# Multi-stage build: deps → build → production runner
# Also installs pandoc for document-conversion routes.
# ──────────────────────────────────────────────────────────────

# ─── Stage 1: Install dependencies ───────────────────────────
FROM node:22-alpine AS deps
WORKDIR /app

# Install OS deps needed for native modules (node-gyp → python3) and document gen.
RUN apk add --no-cache pandoc py3-openpyxl python3 py3-pip

# Install Node deps
COPY package.json package-lock.json ./
RUN npm ci --omit=dev --prefer-offline --no-audit --no-fund

# ─── Stage 2: Build Prisma client & test assets ──────────────
FROM node:22-alpine AS build
WORKDIR /app

RUN apk add --no-cache pandoc py3-openpyxl python3 py3-pip

# Copy prod node_modules from deps stage (avoids re-download)
COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/package.json ./package.json

# Copy source code
COPY . .

# Generate Prisma client (needed at runtime for queries)
RUN npx prisma generate

# ─── Stage 3: Production runner ─────────────────────────────
FROM node:22-alpine AS runner
WORKDIR /app

# Runtime document toolchain for DOCX/XLSX/PPTX/PDF/OCR workflows, plus
# git/openssh-client for APPS/GitHub workspace clone, pull, diff, push.
RUN apk add --no-cache \
    chromium \
    font-liberation \
    font-noto \
    freetype \
    ghostscript \
    git \
    harfbuzz \
    libreoffice \
    nss \
    openssh-client \
    pandoc \
    poppler-utils \
    py3-openpyxl \
    py3-pip \
    python3 \
    tesseract-ocr \
    tesseract-ocr-data-eng \
    tesseract-ocr-data-osd \
    tesseract-ocr-data-spa \
    ttf-dejavu \
    ttf-freefont

# Create non-root user and group if they don't exist
RUN addgroup -S appgroup 2>/dev/null || true; \
    adduser -S appuser -G appgroup 2>/dev/null || true

# Copy only runtime production assets
COPY --from=build --chown=appuser:appgroup /app/node_modules ./node_modules
COPY --from=build --chown=appuser:appgroup /app/package.json ./package.json
COPY --from=build --chown=appuser:appgroup /app/index.js ./index.js
COPY --from=build --chown=appuser:appgroup /app/src ./src
COPY --from=build --chown=appuser:appgroup /app/prisma ./prisma
COPY --from=build --chown=appuser:appgroup /app/scripts ./scripts
COPY --from=build --chown=appuser:appgroup /app/docs ./docs

# Ensure uploads directory exists and is writable. Runtime uploads are mounted or
# generated by the app, so the build context may legitimately not contain one.
RUN mkdir -p /app/uploads && chown -R appuser:appgroup /app/uploads

# Switch to non-root user
USER appuser

# Environment
ENV NODE_ENV=production
ENV PORT=5000
# The /code verify-agent drives the system chromium (Alpine apk) via Playwright;
# Playwright's own bundled browser doesn't run on musl, so point it at the apk
# binary and skip the browser download.
ENV PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/usr/bin/chromium-browser
ENV PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1

EXPOSE 5000

# Healthcheck
HEALTHCHECK --interval=15s --timeout=5s --start-period=20s --retries=3 \
    CMD wget --no-verbose --tries=1 --spider http://localhost:5000/health/live || exit 1

# Use node directly for proper SIGTERM forwarding
CMD ["node", "index.js"]
