{
  "name": "openwebui-backend",
  "version": "1.0.0",
  "description": "Complete backend for OpenWebUI platform",
  "main": "index.js",
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "scripts": {
    "dev": "nodemon index.js",
    "start": "node  index.js",
    "build": "echo 'Build complete'",
    "vercel-build": "prisma generate && prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:setup": "node scripts/setup-db.js",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset",
    "seed": "js-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.js"
  },
  "dependencies": {
    "@elevenlabs/elevenlabs-js": "^2.13.0",
    "@fal-ai/client": "^1.6.2",
    "@google/genai": "^1.20.0",
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^6.11.1",
    "axios": "^1.11.0",
    "bcryptjs": "^3.0.2",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "docx": "^9.5.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.18.1",
    "express-validator": "^7.0.1",
    "form-data": "^4.0.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.6.0",
    "morgan": "^1.10.0",
    "multer": "^2.0.1",
    "node-cron": "^3.0.3",
    "node-fetch": "^2.7.0",
    "nodemailer": "^6.10.1",
    "openai": "^5.10.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "pdf-parse": "^1.1.1",
    "pptxgenjs": "^4.0.1",
    "prisma": "^6.11.1",
    "sharp": "^0.34.3",
    "stripe": "^18.3.0",
    "tesseract.js": "^5.0.4",
    "tiktoken": "^1.0.22",
    "uuid": "^11.1.0",
    "xlsx": "^0.18.5",
    "xml2js": "^0.6.2",
    "zod": "^3.24.1"
