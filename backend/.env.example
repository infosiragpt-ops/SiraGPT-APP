# Server Configuration
PORT=5000
NODE_ENV=development

# Database
PRISMA_DATABASE_URL="mysql://username:password@localhost:3306/openwebui"

# JWT Secret
JWT_SECRET="your-super-secret-jwt-key-here"

# Session Secret
SESSION_SECRET="your-session-secret-here"

# Frontend URL
FRONTEND_URL="http://localhost:3000"

# CORS Origins (comma-separated)
CORS_ORIGINS="http://localhost:3000,http://localhost:3001"

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_DIR="uploads"

# AI API Keys (Add at least one for the system to work)
# Gemini is fastest, then OpenRouter, then OpenAI
GEMINI_API_KEY="your-gemini-api-key-here"
OPENROUTER_API_KEY="your-openrouter-api-key-here"
OPENAI_API_KEY="your-openai-api-key-here"
DEEPSEEK_API_KEY="your-deepseek-api-key-here"

# Academic Search APIs (server-side only; never expose in NEXT_PUBLIC_*)
# Scopus requires Elsevier API entitlement. Insttoken/authtoken are optional institutional credentials.
SCOPUS_API_KEY=""
SCOPUS_INSTTOKEN=""
SCOPUS_AUTHTOKEN=""

# Web of Science requires Clarivate Expanded API entitlement.
# Base URL is configurable because Clarivate examples use different gateways by plan.
WOS_API_KEY=""
WOS_BASE_URL="https://wos-api.clarivate.com/api/wos"
WOS_DATABASE_ID="WOS"
WOS_OPTION_VIEW="SR"

# OpenAlex requires an API key for production-scale usage. Mailto helps identify the app/contact.
OPENALEX_API_KEY=""
OPENALEX_MAILTO="research@example.com"
SEARCH_BRAIN_MAILTO="research@example.com"

# Semantic Scholar Graph API key is optional but recommended.
SEMANTIC_SCHOLAR_API_KEY=""

# PubMed / NCBI E-utilities. API key increases default rate from 3 req/s to 10 req/s.
NCBI_API_KEY=""
NCBI_TOOL="siraGPT"
NCBI_EMAIL="research@example.com"

# DOAJ public article search does not require a key. Publisher/private routes use api_key.
DOAJ_API_KEY=""

# Other AI Providers (Optional)
ANTHROPIC_API_KEY="your-anthropic-api-key-here"
GROQ_API_KEY="your-groq-api-key-here"

# Google OAuth (Optional)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Gmail Integration
GOOGLE_REDIRECT_URI="http://localhost:5000/api/auth/gmail/callback"

# Payment Providers (Optional)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
PAYPAL_CLIENT_ID="your-paypal-client-id"
PAYPAL_CLIENT_SECRET="your-paypal-client-secret"
MERCADOPAGO_ACCESS_TOKEN="your-mercadopago-token"

# Email Configuration (Optional)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
