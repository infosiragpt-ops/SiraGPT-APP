# Server Configuration
PORT=5000
# Production must use the literal value "production"; "prod" is rejected.
NODE_ENV=development
# Explicit RBAC rollout mode. Omitted defaults: production=enforce,
# non-production=shadow. Production rejects any other value at boot.
RBAC_ENFORCEMENT_MODE=shadow
RBAC_CACHE_TTL_MS=60000
RBAC_MUTATION_LOCK_TIMEOUT_MS=500
RBAC_REDIS_CONNECT_TIMEOUT_MS=500
RBAC_REDIS_STARTUP_TIMEOUT_MS=500
RBAC_REDIS_COMMAND_TIMEOUT_MS=500
AUTH_USER_LOCK_TIMEOUT_MS=500
AUTH_REVOCATION_REDIS_CONNECT_TIMEOUT_MS=500
AUTH_REVOCATION_REDIS_COMMAND_TIMEOUT_MS=500
AUTH_SOCKET_REVALIDATION_CACHE_TTL_MS=5000
AUTH_SOCKET_REVALIDATION_TIMEOUT_MS=2000
AUTH_SOCKET_REVALIDATION_CACHE_MAX=2000

# Database
# POSTGRES_* supports Compose-only fallback when all three URL roles below are
# empty. Any explicit URL disables this synthesis.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=siragpt
# Runtime datasource (direct PostgreSQL or prisma+postgres/Accelerate).
PRISMA_DATABASE_URL="postgresql://username:password@localhost:5432/siragpt"
# Direct PostgreSQL datasource for Prisma migrations and boot-time pg checks.
DIRECT_DATABASE_URL="postgresql://username:password@localhost:5432/siragpt"
# Legacy runtime/direct fallback. Keep empty when explicit role URLs are set.
DATABASE_URL=""
# TLS verification defaults on. Only the exact value "false" disables it.
# CA/CERT/KEY accept inline PEM or a PEM file path and override URL values.
DATABASE_SSL_REJECT_UNAUTHORIZED=true
DATABASE_SSL_CA=""
DATABASE_SSL_CERT=""
DATABASE_SSL_KEY=""
# Bounded migration command and pg operation deadlines.
MIGRATION_COMMAND_TIMEOUT_MS=300000
# Auxiliary boot command deadline (for example, fuser stale-port cleanup).
BOOT_COMMAND_TIMEOUT_MS=5000
MIGRATION_DB_CONNECT_TIMEOUT_MS=10000
MIGRATION_DB_QUERY_TIMEOUT_MS=15000
MIGRATION_DB_STATEMENT_TIMEOUT_MS=15000
MIGRATION_LOCK_TIMEOUT_MS=120000
# U0 reviewed one-off only (deploy-production-baseline-* / baseline-migration-history.js).
# Never set on normal boot. Exact phrase required: I_REVIEWED_PRODUCTION_SCHEMA
# MIGRATION_BASELINE_CONFIRM=
# MIGRATION_BASELINE_DRY_RUN=0
# Local normal boot only. Release --migrate-only rejects a value of 1.
SKIP_MIGRATIONS=0
# Applies only to normal boot. --migrate-only never degrades migration errors.
MIGRATION_NONFATAL=0
# Prisma v6 pool controls (max 1-100; timeout 1000-300000ms).
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_POOL_TIMEOUT_MS=10000
# Advisory-only recommendation loop; it never resizes/replaces live Prisma.
DATABASE_POOL_AUTOSCALE_ENABLED=false
DATABASE_POOL_AUTOSCALE_INTERVAL_MS=30000
DATABASE_POOL_AUTOSCALE_MIN=2
DATABASE_POOL_AUTOSCALE_MAX=50
DATABASE_POOL_AUTOSCALE_COLD_SAMPLES=3

# Durable agentic runtime (required for /api/agent/task)
REDIS_URL="redis://localhost:6379"
# Keep compat through the first rolling release. Flip to hash only after every
# compat pod is drained, and acknowledge the cutover explicitly.
SESSION_TOKEN_HASH_MODE=compat
SESSION_TOKEN_HASH_COMPAT_DRAINED=0
SESSION_TOKEN_HASH_BACKFILL_BATCH_SIZE=100
SESSION_TOKEN_HASH_BACKFILL_MAX_BATCHES=10
# Production readiness requires noeviction, Lua, and memory headroom.
AUTH_SECURITY_REDIS_MAX_MEMORY_RATIO=0.8
AUTH_SECURITY_READY_RETRY_BASE_MS=250
AUTH_SECURITY_READY_RETRY_MAX_MS=5000
# One-time OAuth state for Google/Gmail/Services/Spotify/GitHub. Redis is
# mandatory in production; test/development fallback memory is hard bounded.
OAUTH_STATE_TTL=10m
OAUTH_STATE_RETRY_AFTER_SECONDS=5
OAUTH_STATE_CACHE_MAX_ENTRIES=10000
OAUTH_STATE_REDIS_CONNECT_TIMEOUT_MS=500
OAUTH_STATE_REDIS_COMMAND_TIMEOUT_MS=500
OAUTH_STATE_REDIS_PREFIX="sira:oauth-state:"
# Distributed super-admin impersonation sliding windows.
IMPERSONATION_TARGET_LIMIT=3
IMPERSONATION_ADMIN_LIMIT=10
IMPERSONATION_WINDOW_MS=3600000
IMPERSONATION_MEMORY_MAX_KEYS=10000
IMPERSONATION_REDIS_CONNECT_TIMEOUT_MS=500
IMPERSONATION_REDIS_COMMAND_TIMEOUT_MS=500
IMPERSONATION_REDIS_PREFIX="sira:impersonation:"
IMPERSONATION_STORE_RETRY_AFTER_SECONDS=5
AGENT_QUEUE_NAME="siragpt-agent-tasks"
AGENT_WORKER_CONCURRENCY=2
# On boot, recover stale local task snapshots left running/queued after a crash.
AGENT_TASK_BOOT_RECOVERY_DISABLED=false
AGENT_TASK_BOOT_RECOVERY_STALE_MS=60000
AGENTIC_RAG_PROVIDER="internal"
AGENTIC_AGENT_ENGINE="react"

# Internal orchestration gateway. Disabled unless provider keys are present.
SIRAGPT_LLM_GATEWAY_TIMEOUT_MS=45000
SIRAGPT_LLM_GATEWAY_BREAKER_RESET_MS=60000
SIRAGPT_CACHE_TTL_DEFAULT_SECONDS=3600
SIRAGPT_CACHE_TTL_CODE=900
SIRAGPT_CACHE_TTL_SPEED=1800
GOOGLE_AI_API_KEY=""
CEREBRAS_API_KEY=""
# Free-IA fallback is quota-bound per user/day and fails closed when its
# durable zero-amount credit_transactions reservation cannot be persisted.
FREE_IA_FALLBACK_DAILY_LIMIT=10
# In-progress credit operations can be recovered after this lease expires.
# Runtime clamps this to 5 seconds..60 minutes (default: at least 5 minutes
# and always above the configured provider timeout). Active routes heartbeat.
CREDIT_IDEMPOTENCY_LEASE_MS=300000
# One overall deadline covers both paraphrase rewrite passes.
PARAPHRASE_PROVIDER_TIMEOUT_MS=15000
MISTRAL_API_KEY=""
TAVILY_API_KEY=""
FAL_API_KEY=""
FAL_KEY=""
TAL_AI_API_KEY=""
EXA_API_KEY=""
FIRECRAWL_API_KEY=""

# Optional durable cross-session user memory. Requires the
# 20260520180000_add_user_memories_pgvector migration and pgvector.
# Leave SIRAGPT_USER_MEMORY_STORE empty to use the existing RAG fallback.
SIRAGPT_USER_MEMORY_STORE=""
SIRAGPT_MEMORY_EMBED_PROVIDER="voyage"
SIRAGPT_MEMORY_EMBED_MODEL="voyage-3-large"
VOYAGE_API_KEY=""
JINA_API_KEY=""

# Cloudflare R2 artifact storage. Leave empty to keep local artifact storage.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_BUCKET=""
R2_ENDPOINT=""
R2_PRESIGNED_URL_TTL_SECONDS=900

# Optional OpenClaw multichannel sidecar.
OPENCLAW_ENABLED=false
OPENCLAW_GATEWAY_URL=""
OPENCLAW_API_KEY=""
OPENCLAW_CHANNELS="whatsapp,telegram,slack,discord,signal,imessage"
SIRAGPT_INTERNAL_API_URL=""
SIRAGPT_INTERNAL_API_KEY=""
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=""
LANGSMITH_PROJECT="siragpt-agentic-runtime"

# OpenTelemetry distributed tracing.
# Disabled by default unless OTEL_ENABLED=true or an OTLP endpoint is set.
OTEL_ENABLED=false
OTEL_SERVICE_NAME="siragpt-backend"
OTEL_SERVICE_NAMESPACE="siragpt"
OTEL_DEPLOYMENT_ENVIRONMENT="development"
OTEL_TRACES_EXPORTER="otlp"
# You can set either the full traces endpoint or the generic OTLP HTTP endpoint.
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=""
OTEL_EXPORTER_OTLP_ENDPOINT=""
OTEL_EXPORTER_OTLP_HEADERS=""
OTEL_FAIL_FAST=false

# Sentry error monitoring.
# Disabled by default unless SENTRY_DSN is set and SENTRY_ENABLED is true/omitted.
SENTRY_ENABLED=false
SENTRY_DSN=""
SENTRY_ENVIRONMENT="development"
SENTRY_TRACES_SAMPLE_RATE=0
SENTRY_RELEASE=""
# Profile sampling (Phase 8i). Profiles are SUBSAMPLED from already-
# sampled traces, so this only matters when SENTRY_TRACES_SAMPLE_RATE
# is also > 0. Default 0 keeps the @sentry/profiling-node integration
# silent until an operator opts in. Range: 0..1.
SENTRY_PROFILES_SAMPLE_RATE=0

# Langfuse — open-source LLM observability (per-generation traces,
# token usage, cost, latency). Disabled by default; auto-enables when
# both keys are set. Use LANGFUSE_HOST to point at a self-hosted
# instance — leave blank for Langfuse Cloud (https://cloud.langfuse.com).
LANGFUSE_PUBLIC_KEY=""
LANGFUSE_SECRET_KEY=""
LANGFUSE_HOST=""
LANGFUSE_ENVIRONMENT=""
LANGFUSE_RELEASE=""
LANGFUSE_SAMPLE_RATE=1
LANGFUSE_FLUSH_AT=15
LANGFUSE_FLUSH_INTERVAL_MS=10000

# PostHog — open-source product analytics, feature flags, session
# replay, A/B testing. Disabled by default; auto-enables when
# POSTHOG_API_KEY is set. Default host is Cloud US — set POSTHOG_HOST
# to https://eu.i.posthog.com for EU cloud, or to your self-hosted
# instance URL. Backend events: server-authoritative funnel signals
# (plan.upgraded, payment.failed, …). Frontend events live in the
# Next.js app and use the same project/key.
POSTHOG_API_KEY=""
POSTHOG_HOST=""
POSTHOG_ENABLED=""
POSTHOG_ENVIRONMENT=""
POSTHOG_FLUSH_AT=20
POSTHOG_FLUSH_INTERVAL_MS=10000

# LLM cost telemetry (phase 8s). The cost calculator at
# backend/src/services/observability/llm-cost.js prices each LLM
# generation against a frozen per-model table. Unknown models fall
# back to this per-million USD rate so the cost dashboard never
# has gaps (operators want to KNOW about an unmapped model). The
# rate applies to BOTH input and output tokens.
LLM_COST_FALLBACK_PER_MILLION=1.00

# JWT Secret
JWT_SECRET="your-super-secret-jwt-key-here"

# Session Secret
SESSION_SECRET="your-session-secret-here"

# Frontend URL
FRONTEND_URL="http://localhost:3000"

# CORS Origins (comma-separated). REQUIRED in production: missing, malformed,
# or wildcard values fail startup. When unset in development the server falls
# back to localhost:3000 / 3001 so `npm run dev` works without further config.
CORS_ORIGINS="http://localhost:3000,http://localhost:3001"
# Cookie-auth unsafe methods still require a trusted Origin, same-origin or
# same-site fetch metadata, and the CSRF token. The bypass is test/dev only.
CSRF_DISABLED=0
CSRF_PEPPER=

# Express client-IP topology. Zero trusts no forwarded hops (safe default for
# direct binds). Set either a bounded hop count OR exact proxy CIDRs, never both.
TRUST_PROXY_HOPS=0
TRUST_PROXY_CIDR=

# Rate limiting — three tiers: auth endpoints (anti-bruteforce),
# expensive endpoints (agent / RAG / document gen), and the general
# /api/ catch-all. Tunables below have sensible defaults; set them
# when a CDN handles first-pass throttling or when load testing
# demands higher caps.
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=30
RATE_LIMIT_EXPENSIVE_MAX=60
RATE_LIMIT_API_MAX=1000
# Storage backend. "auto" uses Redis when REDIS_URL is set, otherwise
# in-memory. Set "redis" to require the shared store (boot warns if
# REDIS_URL is missing) or "memory" to force per-process counters
# (single-instance deploys + local dev). Multi-instance backends MUST
# use Redis so the cap means the same thing across replicas.
RATE_LIMIT_STORE=auto
RATE_LIMIT_REDIS_PREFIX="rl:"
# Sensitive endpoint policy: production defaults to and only accepts
# "distributed". Outside production, leave blank to infer from RATE_LIMIT_STORE,
# or explicitly use "memory" / "fail-open" for local and test environments.
RATE_LIMIT_SENSITIVE_POLICY=
# Applied both by ioredis and by the outer Promise timeout on every limiter
# command/pipeline (valid range 10-30000ms).
RATE_LIMIT_REDIS_COMMAND_TIMEOUT_MS=1000
RATE_LIMIT_STORE_RETRY_AFTER_SECONDS=5
# Dedicated billing buckets. User limits stay tight; shared-NAT IP limits are
# intentionally much higher. IPv6 clients are grouped by /64.
RATE_LIMIT_BILLING_CHECKOUT_MAX=10
RATE_LIMIT_BILLING_CHECKOUT_IP_MAX=100
RATE_LIMIT_BILLING_VERIFY_MAX=20
RATE_LIMIT_BILLING_VERIFY_IP_MAX=200
RATE_LIMIT_BILLING_PLAN_CHANGE_MAX=5
RATE_LIMIT_BILLING_PLAN_CHANGE_IP_MAX=50
RATE_LIMIT_BILLING_WINDOW_MS=900000
RATE_LIMIT_BILLING_PLAN_WINDOW_MS=3600000
RATE_LIMIT_BILLING_REFUND_MAX=5
RATE_LIMIT_BILLING_REFUND_IP_MAX=50
RATE_LIMIT_BILLING_REFUND_WINDOW_MS=3600000
# SP-initiated SAML AuthnRequest and one-time RelayState cache. Redis is
# mandatory/fail-closed in production; local/test may use bounded memory.
SAML_REQUEST_TTL_MS=300000
SAML_REQUEST_CACHE_MAX_ENTRIES=5000
SAML_REDIS_CONNECT_TIMEOUT_MS=500
SAML_REDIS_COMMAND_TIMEOUT_MS=500
SAML_REDIS_RETRY_BASE_MS=100
SAML_REDIS_RETRY_MAX_MS=5000
SAML_REDIS_PREFIX="sira:saml:"
# Optional dedicated HMAC secret; defaults to JWT_SECRET when empty.
SAML_RELAY_STATE_SECRET=
# Exact SAML ACS ingress controls. The limiter executes before body parsing
# and request telemetry; body bytes are clamped to the safe 64-512 KiB range.
SAML_ACS_BODY_LIMIT_BYTES=262144
SAML_ACS_RATE_LIMIT_MAX=30
SAML_ACS_RATE_LIMIT_WINDOW_MS=60000
# Bound the per-process LRU used only for sampled API-key audit counters.
SIRAGPT_API_KEY_AUDIT_COUNTER_MAX=10000

# Optional defense-in-depth for logs/traces: extend the built-in secret redaction deny lists.
SIRAGPT_REDACT_EXTRA_HEADERS=
SIRAGPT_REDACT_EXTRA_QUERY_KEYS=

# Bucketing identity. The limiter buckets authenticated requests by
# `user:<jwtUserId>` (verified against JWT_SECRET) and anonymous /
# invalid-token requests by `ip:<req.ip>`. Forged tokens fall through
# to the IP bucket so they cannot pin abuse to a victim's quota.

# Plan-quota enforcement (FREE: 3 calls/month from monthlyCallLimit;
# PRO / PRO_MAX / ENTERPRISE: token caps from User.monthlyLimit).
# Gates expensive routes (canary on /api/document-ai today; /api/agent
# and /api/rag follow in 8h2). Default ON: those routes had ZERO
# quota enforcement before phase 8h, so an "off by default" rollout
# would regress production posture.
#
# Set PLAN_QUOTAS_ENFORCED=false ONLY as an emergency rollback when
# a bug causes false-positive 429s. The X-Plan-Quota-* response
# headers continue flowing in disabled mode (read-only telemetry).
# See docs/plan-quotas.md for the full operator runbook.
PLAN_QUOTAS_ENFORCED=true

# Interactive API documentation (Phase 8i). Renders the OpenAPI 3.1
# spec from services/contracts/schema-registry.js into Swagger UI at
# /api-docs. Default ON in non-production NODE_ENV; default OFF in
# production. To expose docs in production set API_DOCS_ENABLED=true
# and gate the route at your reverse proxy (basic auth / VPN / IP
# allowlist) — the spec itself never carries secrets, only endpoint
# shapes, but the rendered explorer can be used to probe the API.
# See docs/api-docs.md for the operator runbook.
API_DOCS_ENABLED=""
API_DOCS_TITLE="siraGPT API"

# File Upload Configuration
# Values are megabytes, not bytes. Default is 100 MB/file when unset.
MAX_FILE_SIZE=50
UPLOAD_MAX_FILE_MB=50
MAX_UPLOAD_FILES=10
# XLSX extraction safety: cap sheets inspected per workbook and neutralize formula-like text.
SIRAGPT_XLSX_MAX_SHEETS=5
SIRAGPT_XLSX_DEFANG_FORMULAS=true
# Only use this in isolated/internal deployments with separate quotas.
ALLOW_UNBOUNDED_UPLOADS=false
UPLOAD_DIR="uploads"

# OCR Pro Hybrid
# Local OCR runs first with Tesseract spa+eng. Vision fallback is used only
# when OCR_MODE=hybrid and local OCR is empty/weak.
OCR_MODE="hybrid"
OCR_MIN_CONFIDENCE=70
OCR_MIN_USEFUL_CHARS=20
OCR_VISION_MODEL=""
# Max concurrent OCR + document analysis workers when a single chat message
# bundles several attachments. Default 3 keeps Tesseract / vision fallback
# from saturating CPU and external Vision API quotas.
MESSAGE_ATTACHMENTS_OCR_CONCURRENCY=3

# Server-side cache of in-flight chat streams (used by GET /api/chats/:id/pending-stream).
# Hard cap on the number of simultaneous resumable streams kept in memory.
# Each entry is small; default 1000 fits comfortably in a single-process
# backend. Increase only if multi-tenant load demands it.
STREAM_CACHE_MAX_ENTRIES=1000

# AI API Keys (Add at least one for the system to work)
# Gemini is fastest, then OpenRouter, then OpenAI
GEMINI_API_KEY="your-gemini-api-key-here"
OPENROUTER_API_KEY="your-openrouter-api-key-here"
OPENAI_API_KEY="your-openai-api-key-here"
DEEPSEEK_API_KEY="your-deepseek-api-key-here"

# Academic Search APIs (server-side only; never expose in NEXT_PUBLIC_*)
# Scopus requires Elsevier API entitlement. Insttoken/authtoken are optional institutional credentials.
SCOPUS_API_KEY=""
SCOPUS_INSTTOKEN=""
SCOPUS_AUTHTOKEN=""

# Web of Science requires Clarivate Expanded API entitlement.
# Base URL is configurable because Clarivate examples use different gateways by plan.
WOS_API_KEY=""
WOS_BASE_URL="https://wos-api.clarivate.com/api/wos"
WOS_DATABASE_ID="WOS"
WOS_OPTION_VIEW="SR"

# OpenAlex requires an API key for production-scale usage. Mailto helps identify the app/contact.
OPENALEX_API_KEY=""
OPENALEX_MAILTO="research@example.com"
SEARCH_BRAIN_MAILTO="research@example.com"

# Semantic Scholar Graph API key is optional but recommended.
SEMANTIC_SCHOLAR_API_KEY=""

# PubMed / NCBI E-utilities. API key increases default rate from 3 req/s to 10 req/s.
NCBI_API_KEY=""
NCBI_TOOL="siraGPT"
NCBI_EMAIL="research@example.com"

# DOAJ public article search does not require a key. Publisher/private routes use api_key.
DOAJ_API_KEY=""

# Other AI Providers (Optional)
ANTHROPIC_API_KEY="your-anthropic-api-key-here"
# Phase 8F native Anthropic SDK provider. When ANTHROPIC_API_KEY is set
# and ANTHROPIC_NATIVE_ENABLED is not "false", the model adapter can use
# the official @anthropic-ai/sdk for direct Claude calls. Leaving the
# flag unset keeps the existing OpenRouter compatibility path active.
ANTHROPIC_NATIVE_ENABLED="true"
ANTHROPIC_NATIVE_MAX_TOKENS=4096
GROQ_API_KEY="your-groq-api-key-here"

# GitHub Codex connector (optional for public repos, required for private repos)
# Use a fine-grained token with read-only metadata, contents, PRs, issues and actions.
# Repository file selection also applies .gitignore automatically; no browser token is accepted.
# GitHub Actions Intelligence uses the same backend token and requires read-only actions access.
GITHUB_CODEX_TOKEN=""
# Backend-only resilience controls for Octokit retry/throttling.
# Retry covers transient GitHub API statuses only: 429, 500, 502, 503 and 504.
GITHUB_CODEX_RETRY_LIMIT=2
GITHUB_CODEX_THROTTLE_MAX_RETRIES=2
GITHUB_CODEX_THROTTLE_RETRY_AFTER_SECONDS=60

# User-registered external MCP servers. Production requires HTTPS whenever MCP
# is enabled. Entries may be exact hosts or safe leading-* subdomain patterns
# such as *.tools.example.com. Empty means MCP deny-all/degraded.
SIRAGPT_MCP_ALLOWED_HOSTS=""
# Development/test only: opt into HTTP for loopback endpoints. Production
# rejects this override even when set.
SIRAGPT_MCP_ALLOW_HTTP=0

# Internal MCP connector hub.
# Comma-separated subset of approved tools:
#   github.codex.status, github.codex.repository_context,
#   rag.retrieve, project.memory.list, document.preview, web.fetch,
#   code.execute
# Both web.fetch and code.execute are intentionally NOT in the
# default below — adding them here only flags visibility; the
# actual outbound / code-execution capability requires their own
# secondary opt-in flags (MCP_WEB_FETCH_ENABLED + allowlist for
# web.fetch; E2B_API_KEY + MCP_CODE_EXECUTE_ENABLED for code.execute).
MCP_CONNECTOR_ALLOWLIST="github.codex.status,github.codex.repository_context,rag.retrieve,project.memory.list,document.preview"

# web.fetch — outbound HTTP from MCP tools. Disabled by default.
# To enable, set BOTH variables AND list web.fetch in
# MCP_CONNECTOR_ALLOWLIST. The implementation rejects IP literals,
# private / loopback / metadata addresses, DNS-resolved private
# addresses (rebinding), and post-redirect host hops outside the
# allowlist. Hard caps: 2 MB body, 30 s timeout. See
# backend/src/services/connectors/web-fetch.js.
MCP_WEB_FETCH_ENABLED=false
MCP_WEB_FETCH_ALLOWED_HOSTS=""
MCP_WEB_FETCH_MAX_BYTES=1048576
MCP_WEB_FETCH_TIMEOUT_MS=10000

# E2B code-interpreter sandbox (Cursor / ChatGPT-tier code execution).
# Disabled by default; set E2B_API_KEY to activate. The wrapper at
# backend/src/services/sandbox/e2b-sandbox.js handles language
# allowlist, timeout caps, and error translation. Set E2B_DOMAIN to
# point at a self-hosted Firecracker deployment (default is E2B
# Cloud). See backend/tests/e2b-sandbox.test.js for the contract.
E2B_API_KEY=""
E2B_DOMAIN=""
E2B_ENABLED=""
E2B_TIMEOUT_MS=60000

# Remote Docker sandbox client (the deployed services/sandbox microservice,
# e.g. https://sandbox.chatagic.com). When BOTH vars are set, the sandbox
# router prefers the remote backend and the doc-agent uses its remote driver.
# The same two values must match the service host's .env (see
# services/sandbox/DEPLOY.md). NOTE: the bare SANDBOX_SESSION_TTL_MS name is
# read by the MICROSERVICE (container TTL); the local session-manager
# workspace TTL is SANDBOX_LOCAL_SESSION_TTL_MS.
SANDBOX_SERVICE_URL=""
SANDBOX_API_KEY=""
# Backend order for the code-execution router: any of remote,e2b,local
SANDBOX_PREFERENCE=""
# 1 = never fall back to local when the remote sandbox is unreachable
SANDBOX_REMOTE_ONLY=""
SANDBOX_REMOTE_TIMEOUT_MS=120000
# Backend order specifically for chat doc-tools (sandbox_bash); e2b is
# excluded by default there because it cannot see session files.
SANDBOX_DOC_TOOLS_PREFERENCE=""
SANDBOX_LOCAL_SESSION_TTL_MS=""
LOCAL_SANDBOX_ENABLED=""
# Document-agent (Cowork) LLM via OpenRouter. Default openai/gpt-4o-mini is
# cheap but wanders on complex edits; a stronger model (e.g. openai/gpt-4o or
# anthropic/claude-3.5-sonnet) gives far higher Cowork-grade reliability.
SIRAGPT_DOC_AGENT_MODEL=""

# code.execute MCP tool (phase 8m). Triple opt-in:
#   1. E2B_API_KEY set (above).
#   2. MCP_CODE_EXECUTE_ENABLED=true.
#   3. `code.execute` listed in MCP_CONNECTOR_ALLOWLIST.
# Any single condition unmet → the tool refuses to run with a
# structured error. The handler is at backend/src/services/
# connectors/mcp-tool-registry.js#code.execute.
MCP_CODE_EXECUTE_ENABLED=false

# Idempotency (phase 8n). Stripe-style replay protection for POST /
# PUT / PATCH endpoints. Clients send Idempotency-Key: <uuid> per
# logical operation; the backend caches the 2xx response for 24h
# (default) and replays it on subsequent retries with the same key.
# Tenant-scoped (per user-id, falls back to per-IP for anon). 4xx /
# 5xx responses are NOT cached. Disabled by default — operators
# enable per environment after verifying their clients send the
# header on idempotent paths.
IDEMPOTENCY_ENABLED=false
IDEMPOTENCY_TTL_SECONDS=86400
IDEMPOTENCY_MAX_KEY_LEN=256
IDEMPOTENCY_REDIS_PREFIX="idem:"

# SSE heartbeat (phase 8n). Streaming chat / agent responses send a
# `:keepalive` SSE comment every N ms so CDN / load-balancer idle
# timers don't sever long-running streams (typical CDN cap: 30 s).
# 25 s default leaves headroom under that cap. Helper at
# backend/src/utils/sse-heartbeat.js — opt-in per route.
# Health check result cache TTL (milliseconds). Default 5000 (5s).
# Reduces DB/Redis load from aggressive monitoring-system polling.
# Set to 0 to disable caching (every request hits the DB).
HEALTH_CACHE_TTL_MS=5000
# Maximum wait for each public database/migration health query.
# Values are clamped to 100-10000ms.
HEALTH_DB_TIMEOUT_MS=1500
# Maximum wait for each public Redis health ping.
# Values are clamped to 100-10000ms.
HEALTH_REDIS_TIMEOUT_MS=1000
# Dedicated bearer token for remote /internal/health/* callers.
# When blank, METRICS_TOKEN is used as the machine-token fallback.
INTERNAL_HEALTH_TOKEN=
# Production denies loopback bypass by default. Enable only when the request
# reaches Node directly; Forwarded/X-Forwarded-* always disable the bypass.
INTERNAL_HEALTH_ALLOW_LOOPBACK=false
# Shared machine token for all Prometheus aliases (/metrics,
# /internal/metrics, /api/se-agents/metrics, /api/free-ia/metrics.prom)
# and fallback internal-health access.
METRICS_TOKEN=
# Production metrics scraping requires the token/session path unless this is
# true. Forwarded/X-Forwarded-* always disable socket-loopback bypass.
METRICS_ALLOW_LOOPBACK=false
# Internal health-history interval, clamped to 1000-2147483647ms.
HEALTH_PROBE_INTERVAL_MS=30000
# Provider probes are not registered unless explicitly enabled.
HEALTH_PROVIDER_PROBES_ENABLED=false
# Scheduling provider probes additionally requires registration above.
# Keep false to avoid periodic paid/rate-limited provider calls.
HEALTH_SCHEDULE_PROVIDER_PROBES=false
# Dedicated BullMQ health query timeout (clamped to 100-10000ms) and
# result cache TTL (clamped to 0-5000ms).
HEALTH_QUEUE_PROBE_TIMEOUT_MS=1500
HEALTH_QUEUE_PROBE_CACHE_TTL_MS=1000
# Optional comma-separated critical queue IDs.
# Production Compose defaults all five registered queues to critical.
# Standard Compose remains noncritical unless configured here.
# A failed critical queue makes readiness unhealthy:
# agent-task,chat-run,codex-runs,document-collections,goal-runs
HEALTH_CRITICAL_QUEUES=

SSE_HEARTBEAT_INTERVAL_MS=25000

# Content Security Policy (phase 8q). Default: enabled in
# report-only mode. Browsers report violations to CSP_REPORT_URI
# (when configured) without blocking content. After a few days of
# observed reports, set CSP_REPORT_ONLY=false to enforce. Each
# directive is independently overridable via CSP_<DIRECTIVE>_SRC.
# See backend/src/middleware/csp-policy.js for the full surface.
CSP_ENABLED=true
CSP_REPORT_ONLY=true
CSP_REPORT_URI=""
# Per-directive overrides (leave blank to use the documented defaults):
CSP_SCRIPT_SRC=""
CSP_STYLE_SRC=""
CSP_CONNECT_SRC=""
CSP_IMG_SRC=""
CSP_FRAME_SRC=""
CSP_FRAME_ANCESTORS=""
CSP_OBJECT_SRC=""
CSP_FONT_SRC=""
CSP_BASE_URI=""
CSP_FORM_ACTION=""
CSP_WORKER_SRC=""

# LLM response cache (phase 8p) — exact-match prompt cache for
# repeat questions / retries / Custom GPT canned answers. v1 keys
# on (user-id, provider, model, temperature@1dp, system-prompt
# hash, normalized-prompt hash). v2 will key on embedding cosine
# similarity. Disabled by default; activates per-tenant caching
# only when SEMANTIC_CACHE_ENABLED=true. Wiring into the chat
# handler is a follow-up (the wrapper is shipped as a scaffold).
SEMANTIC_CACHE_ENABLED=false
SEMANTIC_CACHE_TTL_SECONDS=3600
SEMANTIC_CACHE_REDIS_PREFIX="lcache:"
SEMANTIC_CACHE_MAX_PROMPT_BYTES=65536

# WebAuthn (passkeys) — phase 8l scaffold. Disabled by default.
# To enable, set the relying party ID (your apex domain, no
# scheme / port) and one or more origins (full https:// URLs the
# RP serves from). Multiple origins for prod + staging are
# comma-separated. Origin matching is exact equality (spec
# requirement) — no suffix tricks. WebAuthn registration /
# authentication endpoints are intentionally NOT wired in this
# commit; the scaffold ships the config resolver + challenge
# store. See backend/src/services/webauthn/.
WEBAUTHN_RP_ID=""
WEBAUTHN_RP_NAME="siraGPT"
WEBAUTHN_ORIGIN=""
WEBAUTHN_ENABLED=""
WEBAUTHN_TIMEOUT_MS=60000
WEBAUTHN_CHALLENGE_REDIS_PREFIX="wac:"

# WebAuthn HTTP endpoints (phase 8o). Mounts /api/webauthn/* with
# four routes (register/begin, register/finish, login/begin,
# login/finish). Disabled by default — operator must:
#   1. Set WEBAUTHN_RP_ID + WEBAUTHN_ORIGIN above (config-level gate).
#   2. Set WEBAUTHN_ENDPOINTS_ENABLED=true (router-level gate).
#   3. Add a Credential Prisma model + run prisma migrate (the
#      shipped credential store is in-memory; production deploys
#      need the Prisma backend to persist credentials across
#      process restarts).
# Until all three conditions are met, the routes return a structured
# 404 with the missing-flag hint.
WEBAUTHN_ENDPOINTS_ENABLED=false

# Google OAuth (Optional)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_AUTH_BASE_URL="http://localhost:5000"
GOOGLE_AUTH_URI="http://localhost:5000/api/auth/google/callback"
GOOGLE_REDIRECT_URI="http://localhost:5000/api/auth/gmail/callback"
GOOGLE_REDIRECT_CALENDAR_DRIVE_URI="http://localhost:5000/api/auth/google-services/callback"

# Optional comma-separated exact HTTPS origins for intentional production
# post-OAuth handoffs. Capped at 10 origins / 2048 characters.
OAUTH_POST_CALLBACK_ALLOWED_ORIGINS=""

# GitHub OAuth (Optional)
GITHUB_OAUTH_REDIRECT_URI="http://localhost:5000/api/github/callback"
GITHUB_OAUTH_SUCCESS_REDIRECT="http://localhost:3000/settings"

# Spotify OAuth (Optional)
SPOTIFY_REDIRECT_URI="http://localhost:5000/api/spotify/callback"
SPOTIFY_OAUTH_SUCCESS_REDIRECT="http://localhost:3000/chat"
SPOTIFY_OAUTH_FAILURE_REDIRECT="http://localhost:3000/connections"

# Payment Providers (Optional)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# Opt in only when webhook handling should retrieve a current Stripe subscription snapshot.
STRIPE_WEBHOOK_RETRIEVE_SUBSCRIPTION_STATE=false
# Durable webhook recovery scans committed outbox effects and unresolved user
# mappings. One replica wins each scan through a PostgreSQL advisory lock.
STRIPE_WEBHOOK_RECOVERY_DISABLED=false
STRIPE_WEBHOOK_RECOVERY_INTERVAL_MS=60000
STRIPE_WEBHOOK_RECOVERY_BATCH_SIZE=25
STRIPE_WEBHOOK_RECOVERY_LEASE_MS=120000
STRIPE_WEBHOOK_RECOVERY_BACKOFF_BASE_MS=30000
STRIPE_WEBHOOK_RECOVERY_BACKOFF_MAX_MS=3600000
STRIPE_WEBHOOK_RECOVERY_MAX_ATTEMPTS=8
PAYPAL_CLIENT_ID="your-paypal-client-id"
PAYPAL_CLIENT_SECRET="your-paypal-client-secret"
MERCADOPAGO_ACCESS_TOKEN="your-mercadopago-token"

# Email Configuration (Optional)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"


# ── Scientific paper search APIs (free; no key required for arXiv, OpenAlex, CrossRef, Europe PMC) ──
# Free keys:
#   Semantic Scholar: https://www.semanticscholar.org/product/api
#   NCBI (PubMed):    https://www.ncbi.nlm.nih.gov/account/ → API Key Management
#   CORE:             https://core.ac.uk/services/api
SIRAGPT_RESEARCH_EMAIL=
SEMANTIC_SCHOLAR_API_KEY=
NCBI_API_KEY=
CORE_API_KEY=
RESEARCH_VISION_MODEL=gpt-4o-mini
