// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("PRISMA_DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  password     String
  avatar       String?
  googleId     String?  @unique
  plan         Plan     @default(FREE)
  isAdmin      Boolean  @default(false)
  isSuperAdmin Boolean  @default(false)  // Super admin can impersonate any user
  apiUsage     BigInt      @default(0)
  monthlyCallLimit BigInt  @default(3)        // NEW: counts number of generate calls / month
  monthlyLimit BigInt      @default(1000) 
  
  // Gmail Integration
  gmailTokens  String?  // Store encrypted Gmail OAuth tokens as JSON
  
  // Google Services Integration (Calendar & Drive)
  googleServicesTokens String?  // Store encrypted Google OAuth tokens for Calendar & Drive as JSON

  // Spotify Integration
  spotifyTokens String? // Store encrypted Spotify OAuth tokens as JSON
  
  // Stripe Integration Fields
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?  @unique
  subscriptionStatus   String?  // active, inactive, canceled, past_due
  subscriptionEndDate  DateTime?

  // Personalization — injected into the master system prompt per turn so
  // every LLM call hears the user's voice (not just their chat history).
  locale              String?  // ISO 639-1, e.g. "es", "en". Null → auto-detect from message.
  preferredTone       String?  // e.g. "casual", "formal", "technical", "pedagogical"
  customInstructions  String?  @db.Text  // free-form "what should the assistant know about you"

  // Flexible settings bag — stores the full settings tree from /settings
  // (theme, accent, density, font size, notification prefs, app toggles,
  // etc.). JSON lets us evolve the shape without migrations. Controls
  // that need to be queryable (locale, tone) live in their own columns.
  settings            Json?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  chats     Chat[]
  payments  Payment[]
  apiUsages ApiUsage[]
  sessions  Session[]
  files     File[]
  createdGpts CustomGpt[]
  projects    Project[]
  usageAlerts UsageAlert[]
  notifications Notification[]
  subscriptionEvents SubscriptionEvent[]

  @@map("users")
}

model AiModel {
  id          String   @id @default(cuid())
  name        String   @unique
  displayName String
  provider    String
  description String?
  apiKey      String?
  type        ModelType    @default(TEXT) // <-- NAYA: Model ki type (TEXT/IMAGE)
  icon        String? 
  isActive    Boolean  @default(true)
  
  // Auto-sync tracking fields
  lastSynced   DateTime?
  syncSource   String?   @default("manual") // "api", "manual", "scheduled"
  contextLength Int?     // Model's context window size
  pricing      Json?     // Provider pricing information
  tags         String[]  // Model tags/categories
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("ai_models")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Chat {
  id        String   @id @default(cuid())
  userId    String
  title     String
  model     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt


  isShared   Boolean   @default(false)
  shareId    String?   @unique

  // Lifecycle flags driven from the Settings → Data controls section.
  // `isArchived` hides the chat from the main list without deleting it;
  // `deletedAt` soft-deletes with a 30-day window before hard purge.
  isArchived Boolean   @default(false)
  deletedAt  DateTime?

  // Language policy — persisted resolution of "what language should the
  // assistant reply in for this thread". Set on first turn (or on any
  // explicit "respond in X" instruction); reused on every subsequent turn
  // so short follow-ups like "ok", "continúa", "summarize" don't drift to
  // the model's default language. ISO 639-1 (es, en, pt, fr, …).
  preferredResponseLanguage String?

  googleCalendarContext Json?      // NEW: Store recent Google Calendar event IDs for context

  // Word Connector Integration
  isWordConnectorChat Boolean @default(false)  // Track if this chat is for Word Connector
  wordContent         String? @db.Text         // Store the full Word document HTML content

  // Excel Connector Integration
  isExcelConnectorChat Boolean @default(false) // Track if this chat is for Excel Connector
  excelContent         Json?                   // Store the workbook JSON (Syncfusion openFromJson compatible)

// GPT Integration
  customGptId String?
  customGpt   CustomGpt? @relation(fields: [customGptId], references: [id], onDelete: SetNull)

  // Project Integration — mirrors customGptId. When set, the AI route
  // injects the project's instructions + attached file contents into
  // the system prompt so a chat inside a project answers with that
  // context baked in.
  projectId   String?
  project     Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)

  // Relations
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]
  sharedMessages MessageShare[] @relation("SharedMessages")

  @@map("chats")
}

model Message {
  id        String      @id @default(cuid())
  chatId    String
  role      MessageRole
  content   String      @db.Text
  tokens    BigInt?
  timestamp DateTime    @default(now())
  files     Json?       // Store file references
  metadata  Json?       // Store message metadata (like Gmail connection requirements)
  feedback  String? 

  // Relations
  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model MessageShare {
  id                  String   @id @default(cuid())
  messageId           String   // The original message that was shared
  chatId              String   // The chat this message belongs to
  userMessageId       String   // The user message in the pair
  assistantMessageId  String   // The assistant message in the pair
  sharedAt            DateTime @default(now())

  // Relations
  chat Chat @relation("SharedMessages", fields: [chatId], references: [id], onDelete: Cascade)

  @@map("message_shares")
}

model File {
  id          String   @id @default(cuid())
  userId      String
  filename    String
  originalName String
  mimeType    String
  size        Int
  path        String
  extractedText String? @db.Text
  openaiFileId String? // OpenAI Files API ID
  createdAt   DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  customGptId String?
  customGpt   CustomGpt? @relation("GptKnowledgeFiles", fields: [customGptId], references: [id],onDelete: SetNull)

  // Files attached to a Project. Same pattern as GPT knowledge files:
  // a File can belong to a Project (its extractedText is injected into
  // chats that run inside that project) or stand alone (uploaded to a
  // regular chat). SetNull on delete preserves the File row if the
  // project is removed — the user can reattach it elsewhere.
  projectId   String?
  project     Project?   @relation("ProjectFiles", fields: [projectId], references: [id], onDelete: SetNull)

  @@map("files")
}

model Payment {
  id          String        @id @default(cuid())
  userId      String
  amount      Float
  currency    String        @default("USD")
  status      PaymentStatus @default(PENDING)
  plan        Plan
  provider    PaymentProvider
  providerId  String?       // External payment ID (Stripe session ID, PayPal order ID, etc.)
  
  // Stripe specific fields
  stripeSessionId      String?  @unique
  stripeSubscriptionId String?
  stripeCustomerId     String?
  stripePriceId        String?
  
  metadata    Json?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model ApiUsage {
  id        String   @id @default(cuid())
  userId    String
  model     String
  tokens    BigInt
  cost      Float
  timestamp DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("api_usage")
}

model SystemSettings {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text

  @@map("system_settings")
}
enum ProviderType {
  OpenAI
  Gemini
  OpenRouter
  Groq
  Custom // Mustaqbil ke liye
}
enum ModelType {
  TEXT
  IMAGE
}

enum Plan {
  FREE
  PRO
  PRO_MAX
  ENTERPRISE
}

enum MessageRole {
  USER
  ASSISTANT
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum PaymentProvider {
  STRIPE
  PAYPAL
  MERCADOPAGO
}

model UsageAlert {
  id        String   @id @default(cuid())
  userId    String
  alertType String   // 'api_usage' | 'call_usage'
  threshold Float    // 0.8, 0.9, 1.0
  sentAt    DateTime @default(now())
  
  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("usage_alerts")
}

model Notification {
  id       String   @id @default(cuid())
  userId   String
  type     String   // 'usage_warning', 'payment_failed', 'subscription_ending'
  title    String
  message  String   @db.Text
  severity String   // 'info', 'warning', 'critical'
  read     Boolean  @default(false)
  metadata Json?    // Additional data
  createdAt DateTime @default(now())
  readAt    DateTime?
  
  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("notifications")
}

model SubscriptionEvent {
  id              String   @id @default(cuid())
  userId          String
  eventType       String   // 'created', 'updated', 'canceled', 'reactivated'
  previousPlan    String?
  newPlan         String?
  eventData       Json?    // Store full event data
  stripeEventId   String?  @unique
  processedAt     DateTime @default(now())
  
  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("subscription_events")
}
model AnonymousUsage {
  id          String   @id @default(cuid())
  anonId      String   @unique
  usedQueries Int      @default(0)
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("anonymous_usage")
}

enum GptVisibility {
  PRIVATE
  UNLISTED
  PUBLIC
}

model CustomGpt {
  id          String      @id @default(cuid())
  creatorId   String
  creator     User        @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  
  // Basic Info
  name        String
  description String?     @db.Text
  iconUrl     String?     
  
  // Behavior Configuration
  instructions        String      @db.Text
  greetingMessage     String?     @db.Text
  
  // Model Parameters
  modelName           String      @default("gpt-3.5-turbo")
  temperature         Float       @default(0.7)
  maxTokens           Int?

  // Knowledge Files
  knowledgeFiles      File[]      @relation("GptKnowledgeFiles")

  // 🔹 Add this line (reverse relation for Chat)
  chats               Chat[]

  // Actions
  actions             Json?
  conversationStarters Json?      

  // Publishing
  visibility          GptVisibility @default(PRIVATE)
  shareId             String      @unique @default(cuid())
  category            String?
  isFeatured          Boolean     @default(false)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  @@map("custom_gpts")
}

// Projects — a workspace for chatting against a curated bundle of
// files + custom instructions. Distinct from CustomGpt because:
//   - Projects are always private to their owner (no visibility
//     tier, no shareId, no category/featured machinery).
//   - The goal is task-scoped knowledge ("Research paper Q1",
//     "Thesis methodology") rather than a reusable persona that
//     others can chat with.
//   - Instructions are optional — a project works as a pure
//     file-bucket even with no prompt set.
// Otherwise the wiring is identical to CustomGpt: chats reference
// the project via Chat.projectId, files via File.projectId, and the
// ai.js route reads both and injects them into the system prompt.
model Project {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name         String
  description  String?   @db.Text
  instructions String?   @db.Text   // Optional custom instructions; may be edited any time.

  // Optional star / favourite — powers the "starred first" sort the
  // UI offers alongside recent activity.
  isStarred    Boolean   @default(false)

  // Read-only share — if non-null, /projects/share/<shareId>
  // renders a public snapshot of the project (name, description,
  // file list) without revealing the owner's chats. Toggled via the
  // "share link" control on the detail page.
  shareId      String?   @unique

  // Relations — file bucket + chats created inside this project.
  files       File[]    @relation("ProjectFiles")
  chats       Chat[]
  memories    ProjectMemory[]
  documents   ProjectDocument[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("projects")
  @@index([userId, updatedAt])
}

// Project memory — durable facts the assistant should remember across
// chats inside a project. One row per extracted fact. Populated
// asynchronously after each chat turn by services/project-memory.js:
// the assistant's reply + the preceding user message are handed to a
// small LLM extractor that emits 0-3 short "things worth remembering"
// bullet points (user preferences, the project's scope, decisions
// made). Rows are plain text — this intentionally sidesteps the
// embedding-based RAG machinery in long-term-memory.js because the UI
// just renders the list; semantic retrieval isn't required here.
model ProjectMemory {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fact         String   @db.Text
  sourceChatId String?  // optional pointer to the chat this came from
  createdAt    DateTime @default(now())

  @@map("project_memories")
  @@index([projectId, createdAt])
}

// Project documents — long-form writing surface for each project.
// Think: thesis draft, methodology section, research notes. Edited
// with a Tiptap-based WYSIWYG editor that serialises to Markdown;
// `content` is the authoritative form (Markdown round-trip lets the
// document export cleanly via the existing /api/generate-document
// docx pipeline without a separate HTML path).
//
// Kept separate from File because these are NOT upload artifacts —
// they're live documents the user authors in-app, auto-saved as
// they type. File is for PDFs/images the user brings in; this is
// for prose the user writes.
model ProjectDocument {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  title      String
  content    String   @db.Text         // Markdown source of truth
  // Optional scratchpad for editor-specific state (open/closed sections,
  // cursor position, last-view timestamp) without forcing a schema
  // change every time the editor grows a new affordance.
  meta       Json?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("project_documents")
  @@index([projectId, updatedAt])
}
