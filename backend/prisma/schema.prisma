model MessageShare {
  id                 String   @id @default(cuid())
  messageId          String // The original message that was shared
  chatId             String // The chat this message belongs to
  userMessageId      String // The user message in the pair
  assistantMessageId String // The assistant message in the pair
  sharedAt           DateTime @default(now())

  // Relations
  chat Chat @relation("SharedMessages", fields: [chatId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([chatId])
  @@map("message_shares")
}

model File {
  id            String   @id @default(cuid())
  userId        String
  filename      String
  originalName  String
  mimeType      String
  size          Int
  path          String
  extractedText String?  @db.Text
  openaiFileId  String? // OpenAI Files API ID
  createdAt     DateTime @default(now())

  // Processing state machine — written by the upload pipeline and the
  // RAG indexer. Stages, in order: uploaded → validating → extracting
  // → chunking → embedding → indexing → ready (or → failed at any
  // step). The frontend polls /api/files/:id/processing-status and
  // surfaces the current stage / error in the attachment chip so the
  // chat never sits on a silent spinner when the pipeline stalls.
  // Nullable to keep legacy rows queryable without a backfill.
  processingStage   String?
  processingError   String?
  processingStageAt DateTime?

  // Relations
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  documentAnalysis DocumentAnalysis?
  documentChunks   DocumentChunk[]
  documentTables   DocumentTable[]
  documentNodes    DocumentNode[]

  customGptId String?
  customGpt   CustomGpt? @relation("GptKnowledgeFiles", fields: [customGptId], references: [id], onDelete: SetNull)

  // Files attached to a Project. Same pattern as GPT knowledge files:
  // a File can belong to a Project (its extractedText is injected into
  // chats that run inside that project) or stand alone (uploaded to a
  // regular chat). SetNull on delete preserves the File row if the
  // project is removed — the user can reattach it elsewhere.
  projectId String?
  project   Project? @relation("ProjectFiles", fields: [projectId], references: [id], onDelete: SetNull)

  // Soft-delete tombstone for GDPR / "Trash" workflows. Hard purge
  // happens via the daily cron after a 30-day grace window.
  deletedAt DateTime?

  @@index([userId, createdAt])
  @@index([customGptId])
  @@index([projectId])
  @@index([userId, deletedAt])
  @@map("files")
}

model DocumentAnalysis {
  id           String   @id @default(cuid())
  userId       String
  fileId       String   @unique
  status       String   @default("pending")
  language     String?
  mimeType     String?
  pageCount    Int?
  sheetCount   Int?
  slideCount   Int?
  charCount    Int      @default(0)
  chunkCount   Int      @default(0)
  tableCount   Int      @default(0)
  summary      String?  @db.Text
  textCoverage Json?
  ocr          Json?
  warnings     Json?
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  file   File            @relation(fields: [fileId], references: [id], onDelete: Cascade)
  chunks DocumentChunk[]
  tables DocumentTable[]
  nodes  DocumentNode[]

  @@index([userId, updatedAt])
  @@map("document_analyses")
}

model DocumentChunk {
  id           String   @id @default(cuid())
  analysisId   String
  fileId       String
  ordinal      Int
  sourceType   String
  sourceLabel  String?
  pageNumber   Int?
  sheetName    String?
  slideNumber  Int?
  sectionTitle String?
  text         String   @db.Text
  charCount    Int      @default(0)
  metadata     Json?
  createdAt    DateTime @default(now())

  analysis DocumentAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  file     File             @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([analysisId, ordinal])
  @@index([fileId, ordinal])
  @@map("document_chunks")
