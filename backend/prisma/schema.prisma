  USER
  ASSISTANT
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum PaymentProvider {
  STRIPE
  PAYPAL
  MERCADOPAGO
}

model UsageAlert {
  id        String   @id @default(cuid())
  userId    String
  alertType String // 'api_usage' | 'call_usage'
  threshold Float // 0.8, 0.9, 1.0
  sentAt    DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sentAt])
  @@map("usage_alerts")
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  // Ratchet 44 — org-scoped notifications (cycle 165). When the row was
  // produced by an org-wide broadcast (POST /api/orgs/:id/notifications)
  // the originating organization is recorded here so the inbox can
  // surface a badge / filter and so the FE knows which org context the
  // notification belongs to. NULL for plain user-targeted rows.
  orgId     String?
  type      String // 'usage_warning', 'payment_failed', 'subscription_ending'
  title     String
  message   String    @db.Text
  severity  String // 'info', 'warning', 'critical'
  read      Boolean   @default(false)
  metadata  Json? // Additional data
  createdAt DateTime  @default(now())
  readAt    DateTime?

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, read])
  @@index([orgId, createdAt])
  @@map("notifications")
}

model SubscriptionEvent {
  id            String   @id @default(cuid())
  userId        String
  eventType     String // 'created', 'updated', 'canceled', 'reactivated'
  previousPlan  String?
  newPlan       String?
  eventData     Json? // Store full event data
  stripeEventId String?  @unique
  processedAt   DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, processedAt])
  @@index([eventType, processedAt])
  @@map("subscription_events")
}

model AnonymousUsage {
  id          String   @id @default(cuid())
  anonId      String   @unique
  usedQueries Int      @default(0)
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("anonymous_usage")
}

enum GptVisibility {
  PRIVATE
  UNLISTED
  PUBLIC
}

model CustomGpt {
  id        String @id @default(cuid())
  creatorId String
  creator   User   @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  // Basic Info
  name        String
  description String? @db.Text
  iconUrl     String?

  // Behavior Configuration
  instructions    String  @db.Text
  greetingMessage String? @db.Text

  // Model Parameters
  modelName   String @default("gpt-3.5-turbo")
  temperature Float  @default(0.7)
  maxTokens   Int?

  // Knowledge Files
  knowledgeFiles File[] @relation("GptKnowledgeFiles")

  // 🔹 Add this line (reverse relation for Chat)
  chats Chat[]

  // Actions
  actions              Json?
  conversationStarters Json?

  // Publishing
  visibility GptVisibility @default(PRIVATE)
  shareId    String        @unique @default(cuid())
  category   String?
  isFeatured Boolean       @default(false)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  // Soft-delete tombstone — owner-driven GDPR deletes hide the GPT
  // from the creator dashboard without cascading on shared chats.
  deletedAt DateTime?

  @@index([creatorId, updatedAt])
  @@index([visibility, isFeatured])
  @@index([creatorId, deletedAt])
  @@map("custom_gpts")
}

// Projects — a workspace for chatting against a curated bundle of
// files + custom instructions. Distinct from CustomGpt because:
//   - Projects are always private to their owner (no visibility
//     tier, no shareId, no category/featured machinery).
//   - The goal is task-scoped knowledge ("Research paper Q1",
//     "Thesis methodology") rather than a reusable persona that
//     others can chat with.
//   - Instructions are optional — a project works as a pure
//     file-bucket even with no prompt set.
// Otherwise the wiring is identical to CustomGpt: chats reference
// the project via Chat.projectId, files via File.projectId, and the
// ai.js route reads both and injects them into the system prompt.
model Project {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name         String
  description  String? @db.Text
  instructions String? @db.Text // Optional custom instructions; may be edited any time.

  // Project kind — chosen at creation. "general" is the default
  // task workspace; "webapp" projects also surface in the Library →
  // "Apps web" gallery so the user can find their web apps there.
  type String @default("general")

  // Where the project's code is hosted. "sira-cloud" is the built-in
  // SiraGPT cloud workspace; "github" is reserved for the upcoming
  // GitHub-backed flow (OAuth + repo push) — not yet wired.
  hostingProvider String @default("sira-cloud")

  // Optional star / favourite — powers the "starred first" sort the
  // UI offers alongside recent activity.
  isStarred Boolean @default(false)

  // Read-only share — if non-null, /projects/share/<shareId>
  // renders a public snapshot of the project (name, description,
  // file list) without revealing the owner's chats. Toggled via the
  // "share link" control on the detail page.
  shareId String? @unique

  // Relations — file bucket + chats created inside this project.
  files     File[]            @relation("ProjectFiles")
  chats     Chat[]
  memories  ProjectMemory[]
  documents ProjectDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Soft-delete tombstone. The Project list view should filter on
  // `deletedAt: null` via the prisma-soft-delete helper.
  deletedAt DateTime?

  @@index([userId, updatedAt])
  @@index([userId, deletedAt])
  @@map("projects")
}

// Project memory — durable facts the assistant should remember across
// chats inside a project. One row per extracted fact. Populated
// asynchronously after each chat turn by services/project-memory.js:
// the assistant's reply + the preceding user message are handed to a
// small LLM extractor that emits 0-3 short "things worth remembering"
// bullet points (user preferences, the project's scope, decisions
// made). Rows are plain text — this intentionally sidesteps the
// embedding-based RAG machinery in long-term-memory.js because the UI
// just renders the list; semantic retrieval isn't required here.
model ProjectMemory {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fact         String   @db.Text
  sourceChatId String? // optional pointer to the chat this came from
  createdAt    DateTime @default(now())

  @@index([projectId, createdAt])
  @@map("project_memories")
}

// Project documents — long-form writing surface for each project.
// Think: thesis draft, methodology section, research notes. Edited
// with a Tiptap-based WYSIWYG editor that serialises to Markdown;
// `content` is the authoritative form (Markdown round-trip lets the
// document export cleanly via the existing /api/generate-document
// docx pipeline without a separate HTML path).
//
// Kept separate from File because these are NOT upload artifacts —
// they're live documents the user authors in-app, auto-saved as
// they type. File is for PDFs/images the user brings in; this is
// for prose the user writes.
model ProjectDocument {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  title   String
  content String @db.Text // Markdown source of truth
  // Optional scratchpad for editor-specific state (open/closed sections,
  // cursor position, last-view timestamp) without forcing a schema
  // change every time the editor grows a new affordance.
  meta    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId, updatedAt])
  @@map("project_documents")
}

// Design projects — the siraGPT Design studio. Each row is one
// Claude-Design-style artifact (prototype, slide deck, or arbitrary
// "other" page) that the user iterates on via chat. The `html`
// column holds the current full single-file HTML document rendered
// in the canvas iframe; the `messages` JSON is the append-only
// conversation that produced it.
//
// We store the full HTML (not a diff log) because the generation
// prompt asks the model to emit the complete updated document per
// turn — that's what makes iteration deterministic. A diff history
// could go in a sibling table if we ever want step-by-step replay,
// but the UX the user gets from "last stable version" is just the
// current `html`.
model DesignProject {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name     String
  // Creation shape: prototype | slide_deck | template | other.
  // Controls what system prompt is selected in the generator and
  // what container the canvas renders in (slides get a 16:9 stage,
  // prototypes get a responsive frame, etc.).
  kind     String
  // Prototype-only: "wireframe" or "high" fidelity. Null for other
  // kinds. The wireframe mode tells the generator to use grey
  // placeholders and system-ui type; high-fidelity gives branded
  // palette + serif display type.
  fidelity String?

  // Optional user-written speaker notes toggle for slide_deck.
  speakerNotes Boolean? @default(false)

  // The current canonical HTML document. May be null before the
  // first generation.
  html     String? @db.Text
  // Append-only conversation. Shape: [{role, content, at}]. Kept
  // inline rather than in Message rows because chats in design
  // projects aren't part of the user's regular Chat history — they
  // are artifacts of the design iteration and should live with the
  // design.
  messages Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, updatedAt])
  @@map("design_projects")
}

// ─── Marketing — agente de publicación programada ─────────────────────────
//
// One row per scheduled / published social post. The UI (/marketing)
// lets the user write an idea, pick a posting time on a calendar,
// choose target networks, and generate the post image with the
// OpenAI image model. We store the *intent* here — real distribution
// to the networks is a worker's job (out-of-band), so `status` moves
// draft → scheduled → publishing → published | failed.
model ScheduledPost {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // The user-provided prompt / idea the agent will post about.
  prompt  String  @db.Text
  // Optional caption shown on the social card. When null the UI
  // derives one from the prompt.
  caption String? @db.Text

  // Server-generated image URL. Currently a data: URL or a persisted
  // file path — depending on how we stored the OpenAI result.
  imageUrl   String? @db.Text
  // The image model used (`openai/gpt-5.4-image-2` today).
  imageModel String?

  // Target platforms as a JSON array of strings:
  //   ["facebook", "instagram", "youtube", "tiktok", "linkedin"]
  platforms Json

  // Absolute publish time in UTC. Null = draft, not yet scheduled.
  scheduledAt DateTime?

  // draft | scheduled | publishing | published | failed | cancelled
  status String @default("draft")

  // Freeform config (filters the composer exposes — color /
  // orientation / animation / price / extra knobs the frontend may
  // add over time). Kept as JSON so we don't have to migrate every
  // time the product grows a new toggle.
  config Json?

  // Reference images the user uploaded so the agent grounds its
  // generation on brand assets. Shape: array of { name, dataUrl,
  // size, type }. Kept inline in the row for now; future migration
  // to S3 / uploads table when size becomes a concern.
  referenceImages Json?

  // Auto-series batch id — posts generated together by the
  // "Programación automática" flow share one batchId so the UI can
  // group them ("Serie de 10 posts · 24-29 abril"). Null for
  // one-off posts.
  batchId String?

  // Last worker attempt metadata. Populated by the scheduler when it
  // tries to publish. Useful for the UI's "re-try" button.
  lastError   String?   @db.Text
  publishedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, scheduledAt])
  @@index([userId, status])
  @@map("scheduled_posts")
}

// ─── Marketing — social-account OAuth connections ─────────────────────────
//
// One row per (user × platform). We persist the access token the user
// granted us when they clicked "Conectar con Facebook" (or Instagram /
// YouTube / TikTok / LinkedIn), plus a snapshot of the account profile
// so the LLM can ground its suggestions ("voy a escribir como
// @tu_marca, que vende X a un público Y").
//
// Tokens are stored raw for now; wire up encryption when the rest of
// the app (Gmail / Spotify tokens) gets the same treatment.
model SocialConnection {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  platform     String // facebook | instagram | youtube | tiktok | linkedin
  accountId    String? // platform-side user id / page id
  accountName  String? // handle displayed to the user ("@tu_marca")
  accessToken  String?   @db.Text
  refreshToken String?   @db.Text
  expiresAt    DateTime?

  // Profile snapshot the LLM grounds post generation on:
  //   { name, bio, website, industry, recentPosts: [...] }
  profile Json?
  scopes  Json? // OAuth scopes granted

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, platform])
  @@index([userId])
  @@map("social_connections")
}

model UniversalSearchCache {
  id               String   @id @default(cuid())
  queryHash        String
  intentCategories String[]
  region           String
  provider         String
  resultJson       Json
  embeddingJson    Json?
  metadata         Json?
  cachedAt         DateTime @default(now())
  ttlSeconds       Int

  @@unique([queryHash, provider])
  @@index([queryHash])
  @@index([provider, cachedAt])
  @@map("universal_search_cache")
}

model SearchBrainSettings {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  region    String   @default("global")
  mode      String   @default("local")
  userEmail String?
  keys      Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("search_brain_settings")
}

model SchedulerJob {
  id           String    @id
  name         String
  schedule     String
  enabled      Boolean   @default(true)
  state        String    @default("idle")
  nextRunAt    DateTime?
  lastRunAt    DateTime?
  lastError    String?
  runCount     Int       @default(0)
  successCount Int       @default(0)
  failureCount Int       @default(0)
  lockedBy     String?
  lockedUntil  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([nextRunAt])
  @@index([state])
  @@index([lockedUntil])
  @@map("scheduler_jobs")
}

model SchedulerRun {
  runId      String    @id
  jobId      String
  startedAt  DateTime
  finishedAt DateTime?
  status     String
  attempt    Int       @default(0)
  error      String?
  durationMs Int?

  @@index([jobId])
  @@index([startedAt])
  @@index([status])
  @@map("scheduler_runs")
}

// Audit log — one row per state-changing action observable in the
// system. Designed to answer "who did what to which resource, and
// what did it look like before vs. after". The before/after JSON
// blobs are intentionally schema-less so any subsystem (chats,
// projects, files, settings, agent tasks…) can write audit rows
// without coupling its shape to this table.
//
// Fields:
//   - actorType: 'user' | 'agent' | 'system' | 'api' | 'admin'
//   - actorId: stable id of the actor (User.id, agent name, …)
//   - actorName: optional human-readable label (email, "scheduler")
//   - resourceType: domain noun ('chat', 'project', 'file', 'user', …)
//   - resourceId: id of the touched resource (nullable for collection-
//     scoped events like 'login')
//   - action: imperative verb ('create' | 'update' | 'delete' |
//     'access' | 'login' | 'export' | …)
//   - before / after: full or partial snapshots of the resource
//   - diff: computed shallow diff of changed keys (for fast filter)
//   - metadata: free-form context (ip, userAgent, requestId, reason)
// Record of a user accepting a versioned legal document (Privacy
// Policy, Terms of Service, etc.). One row per (user, document, version)
// — re-acceptance of the same version is idempotent, but acceptance of
// a new version creates a new row so we keep the full history.
//
// Persisted IP + UA give us evidence of WHO accepted WHAT and FROM WHERE,
// which is what regulators ask for in a GDPR/CCPA audit. The audit_log
// table also gets a row per acceptance for the cross-resource trail.
model PolicyAcceptance {
  id         String   @id @default(cuid())
  userId     String
  document   String // 'privacy-policy' | 'terms-of-service' | …
  version    String
  ip         String?
  ua         String?
  acceptedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, document, version])
  @@index([userId, document])
  @@index([document, version])
  @@map("policy_acceptance")
}

// ─── API Keys (ratchet 45) ──────────────────────────────────────────
//
// Org-scoped bearer credentials for programmatic access. Tokens are
// presented as `sk_<prefix><secret>`; only the SHA-256 hash of the
// full plaintext (after the `sk_` tag) lives in the DB. The 8-char
// `prefix` is safe to display — the middleware looks up by prefix,
// then verifies the hash. `organizationId` is optional: when set, the
// key acts on behalf of that org and the bearer is treated as the
// owning `userId` with the org context attached to req.organization.
model ApiKey {
  id                 String    @id @default(cuid())
  name               String
  prefix             String
  tokenHash          String    @unique
  organizationId     String?
  userId             String
  scopes             String[]  @default([])
  lastUsedAt         DateTime?
  expiresAt          DateTime?
  createdAt          DateTime  @default(now())
  // Ratchet 45 — per-scope last-used aggregate populated by a sampled
  // (1-in-50) fire-and-forget update from requireScope(). Shape:
  // { "<scope>": { count: number, lastUsedAt: ISOString } }
  usedScopes         Json?
  // Ratchet 45 (Task 2) — sibling histogram populated by the same
  // requireScope() sampler keyed by the Express-matched route template.
  // Shape: { "<METHOD> <pathPattern>": count }
  usedEndpoints      Json?
  // Ratchet 45 — optional per-key override of the plan-derived default
  // (env SIRAGPT_API_KEY_DEFAULT_RPM, fallback 60). Requests per minute;
  // null means "use the plan default for the owning user/org".
  rateLimitPerMinute Int?
  // Ratchet 45 (TrueDelete) — soft-delete tombstone. When non-null the
  // key is no longer accepted by the auth middleware, but the row is
  // preserved so audit/forensics can still attribute past activity.
  // A dedicated admin purge endpoint hard-deletes rows where
  // deletedAt is set.
  deletedAt          DateTime?

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([prefix])
  @@index([organizationId, createdAt])
  @@index([userId, createdAt])
  @@index([deletedAt])
  @@map("api_keys")
}

model AuditLog {
  id           String   @id @default(cuid())
  actorType    String
  actorId      String?
  actorName    String?
  resourceType String
  resourceId   String?
  action       String
  before       Json?
  after        Json?
  diff         Json?
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([actorType, actorId, createdAt])
  // audit-query DSL `byUser` filters on `actorId` alone (no actorType
  // predicate) — the composite (actorType, actorId, createdAt) above
  // can't be used as a prefix in that case, so we add a dedicated
  // (actorId, createdAt) covering index. byAction → (action, createdAt)
  // and byResource → (resourceType, resourceId, createdAt) are already
  // covered above.
  @@index([actorId, createdAt])
  @@index([resourceType, resourceId, createdAt])
  @@index([action, createdAt])
  @@index([createdAt])
  @@map("audit_log")
}

// Document index cache — keyed by SHA-256 of the source file's bytes.
// Stores the output of the RAG pipeline (chunks + embeddings + optional
// hierarchy root) so identical re-uploads short-circuit. `pageHashes` is
// an array of per-page (or per-chunk-group) hashes for incremental
// recompute: when the user re-uploads a near-identical file, the store
// reuses embeddings of pages whose hash is unchanged and only recomputes
// the rest.
model DocumentIndex {
  contentHash     String   @id
  version         Int      @default(1)
  chunks          Json
  embeddings      Json
  pageHashes      Json?
  hierarchyRootId String?
  bytesSize       Int      @default(0)
  embedTokens     Int      @default(0)
  metadata        Json?
  createdAt       DateTime @default(now())
  accessedAt      DateTime @default(now())
  hitCount        Int      @default(0)

  @@index([accessedAt])
  @@index([createdAt])
  @@index([hierarchyRootId])
  @@map("document_index")
}

// ─── Organizations / Teams (cycle 27) ───────────────────────────────
//
// Multi-tenant scaffolding. An Organization is a workspace owned by
// one user (`ownerId`) and joined by N users via `OrgMembership` rows.
// `slug` is a URL-friendly handle (unique). `billingPlan` mirrors the
// per-user `Plan` enum but at org level so a team can subscribe to
// PRO/ENTERPRISE collectively.
//
// `monthlyQuota` / `usedThisMonth` track AI request budget when a user
// acts "on behalf of" an organization (see middleware/enforce-org-quota.js).
// Counters reset on the calendar month rollover.

model Organization {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  billingPlan   Plan     @default(FREE)
  ownerId       String
  monthlyQuota  BigInt   @default(10000)
  usedThisMonth BigInt   @default(0)
  quotaResetAt  DateTime @default(now())
  settings      Json?
  ssoConfig     Json?
  ssoEnabled    Boolean  @default(false)
  ssoDomains    String[] @default([])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  owner             User                 @relation("OrganizationOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  memberships       OrgMembership[]
  invitations       OrgInvitation[]
  chats             Chat[]
  webhookEndpoints  WebhookEndpoint[]
  slackIntegrations SlackIntegration[]
  apiKeys           ApiKey[]
  announcements     OrgAnnouncement[]
  pendingTransfers  OrgPendingTransfer[]

  @@index([ownerId])
  @@index([slug])
  @@map("organizations")
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

model OrgMembership {
  id        String   @id @default(cuid())
  orgId     String
  userId    String
  role      OrgRole  @default(MEMBER)
  createdAt DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@index([userId])
  @@index([orgId, role])
  @@map("org_memberships")
}

// Pending email invitations into an organization. The token is a
// cryptographically-strong random string sent via magic link. The
// invitee redeems by POST /api/orgs/invitation/:token/accept while
// authenticated; the route enforces email match.
model OrgInvitation {
  id         String    @id @default(cuid())
  orgId      String
  email      String
  role       OrgRole   @default(MEMBER)
  token      String    @unique
  invitedBy  String
  acceptedAt DateTime?
  expiresAt  DateTime
  createdAt  DateTime  @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  inviter      User         @relation("OrgInvitationInviter", fields: [invitedBy], references: [id], onDelete: Cascade)

  @@index([orgId, email])
  @@index([email])
  @@map("org_invitations")
}

// ── Codex Agent V2 (flag CODEX_AGENT_V2) — spec docs/codex-agent-ux.md §4 ──
// Proyectos con workspace git en el runner + corridas server-driven con
// timeline append-only (codex_events) reproducible tras recarga.

model CodexProject {
  id            String   @id @default(cuid())
  userId        String
  name          String
  status        String   @default("provisioning") // provisioning | ready | error
  workspacePath String? // relativo al volumen del runner: projects/<id>
  previewUrl    String?
  brief         Json?
  error         String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  runs        CodexRun[]
  checkpoints CodexCheckpoint[]

  @@index([userId, updatedAt])
  @@map("codex_projects")
}

model CodexRun {
  id         String    @id @default(cuid())
  projectId  String
  userId     String
  mode       String // plan | build
  status     String    @default("queued") // queued | running | waiting_approval | done | error | cancelled
  jobId      String?   @unique
  prompt     String?   @db.Text // user's context/instructions for this run
  model      String?
  tier       String?
  planRunId  String?
  error      String?   @db.Text
  createdAt  DateTime  @default(now())
  startedAt  DateTime?
  finishedAt DateTime?
  updatedAt  DateTime  @updatedAt

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  project     CodexProject      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  events      CodexEvent[]
  actions     CodexAction[]
  checkpoints CodexCheckpoint[]
  metric      CodexRunMetric?

  @@index([projectId, createdAt])
  @@index([userId, status, updatedAt])
  @@map("codex_runs")
}

model CodexEvent {
  id        String   @id @default(cuid())
  runId     String
  seq       Int
  type      String
  payload   Json
  createdAt DateTime @default(now())

  run CodexRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, seq])
  @@index([runId, createdAt])
  @@map("codex_events")
}

model CodexAction {
  id            String   @id @default(cuid())
  runId         String
  kind          String // terminal | file_read | file_write | reasoning | web
  command       String?  @db.Text
  path          String?
  outputSummary String?  @db.Text
  status        String   @default("running") // running | done | error
  durationMs    Int?
  linesRead     Int?
  groupId       String?
  createdAt     DateTime @default(now())

  run CodexRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, createdAt])
  @@map("codex_actions")
}

model CodexCheckpoint {
  id        String   @id @default(cuid())
  runId     String
  projectId String
  commitSha String
  title     String
  createdAt DateTime @default(now())

  run     CodexRun     @relation(fields: [runId], references: [id], onDelete: Cascade)
  project CodexProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@map("codex_checkpoints")
}

model CodexRunMetric {
  id              String   @id @default(cuid())
  runId           String   @unique
  timeWorkedMs    Int      @default(0)
  actionsCount    Int      @default(0)
  itemsReadLines  Int      @default(0)
  additions       Int      @default(0)
  deletions       Int      @default(0)
  tokensIn        Int      @default(0)
  tokensOut       Int      @default(0)
  costUsd         Float    @default(0)
  costSource      String   @default("estimated") // provider_exact | openrouter_generation | estimated
  costOriginalUsd Float    @default(0)
  costAppliedUsd  Float    @default(0)
  createdAt       DateTime @default(now())

  run CodexRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@map("codex_run_metrics")
}

// Ratchet 44 — pending ownership transfer (cycle 76).
//
// When `settings.transfer.requireApprovalDays > 0`, the existing OWNER
// initiates the swap via POST /api/orgs/:id/transfer-ownership/request
// which inserts a row here instead of mutating the membership graph
// in-line. The proposed new owner has `expiresAt - requestedAt` to
// accept via POST /api/orgs/transfer-requests/:id/accept; the current
// owner can rescind via DELETE on the same id. Once accepted, the row
// is stamped with `acceptedAt` and the live transfer logic runs.
model OrgPendingTransfer {
  id          String    @id @default(cuid())
  orgId       String
  fromOwnerId String
  toOwnerId   String
  requestedAt DateTime  @default(now())
  expiresAt   DateTime
  acceptedAt  DateTime?

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  fromOwner    User         @relation("OrgPendingTransferFrom", fields: [fromOwnerId], references: [id], onDelete: Cascade)
  toOwner      User         @relation("OrgPendingTransferTo", fields: [toOwnerId], references: [id], onDelete: Cascade)

  @@index([orgId, acceptedAt])
  @@index([toOwnerId, acceptedAt])
  @@index([expiresAt])
  @@map("org_pending_transfers")
}

// Ratchet 45 — SSO identity link (cycle 144).
//
// Tracks the external IdP identity (SAML nameID / OIDC sub) that
// authenticated a given local User into a given Organization. A user
// can have one identity per (provider, externalId) tuple — re-logins
// hit the existing row and refresh `lastUsedAt`. This decouples local
// auth (email/password, magic-link, passkey) from the SSO trust chain
// so we can later support multiple IdPs per user, identity-merging
// flows, and admin-side "who logged in from where" forensics.
model SSOIdentity {
  id         String   @id @default(cuid())
  userId     String
  orgId      String
  provider   String
  externalId String
  createdAt  DateTime @default(now())
  lastUsedAt DateTime @default(now())

  @@unique([provider, externalId])
  @@index([userId])
  @@index([orgId])
  @@map("sso_identities")
}

// Org-wide announcements (ratchet 45).
//
// ADMIN+ members can publish banner-style announcements to every
// member of the organization. Rows can carry an optional
// `expiresAt` after which the GET feed hides them, and a severity
// level so the UI can choose styling.
enum OrgAnnouncementSeverity {
  info
  warn
  critical
}

model OrgAnnouncement {
  id          String                  @id @default(cuid())
  orgId       String
  title       String
  body        String
  createdById String
  severity    OrgAnnouncementSeverity @default(info)
  createdAt   DateTime                @default(now())
  expiresAt   DateTime?

  organization Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdBy    User                  @relation("OrgAnnouncementCreator", fields: [createdById], references: [id], onDelete: Cascade)
  reads        OrgAnnouncementRead[]

  @@index([orgId, createdAt])
  @@index([orgId, expiresAt])
  @@index([createdById])
  @@map("org_announcements")
}

// Ratchet 45 — per-user read receipts for org announcements.
//
// One row per (announcementId, userId) the first time a member
// acknowledges they read an announcement. The GET feed joins against
// this table for the requesting user to expose
// `acknowledgedByCurrentUser` on each item.
model OrgAnnouncementRead {
  id             String   @id @default(cuid())
  announcementId String
  userId         String
  readAt         DateTime @default(now())

  announcement OrgAnnouncement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId])
  @@index([userId])
  @@map("org_announcement_reads")
}

// Email verification token (ratchet 45).
//
// Short-lived magic-link tokens. The verify-email endpoint looks up
// a row by `token`, checks it is unread + unexpired, sets
// `User.emailVerifiedAt`, and marks the row consumed. Resend mints
// a new row — previous unconsumed rows for the same user are left
// alone but expire on their own clock.
model EmailVerificationToken {
  id         String    @id @default(cuid())
  userId     String
  token      String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verification_tokens")
}

// Password reset token (spec §7.13).
//
// Single-use, short-lived (default 30m, override with
// PASSWORD_RESET_TTL_MS). Forgot-password endpoint mints a row and emails
// the link; reset endpoint validates the row, updates `User.password`,
// and marks the row consumed.
model PasswordResetToken {
  id              String    @id @default(cuid())
  userId          String
  token           String    @unique
  expiresAt       DateTime
  consumedAt      DateTime?
  createdAt       DateTime  @default(now())
  requestedFromIp String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

// Phone-verification challenge (ratchet 45, Task 1).
//
// Holds the bcrypt-hashed 6-digit SMS code issued by
// `PUT /api/users/me/phone`. Single-use, TTL 10 minutes (override with
// `PHONE_VERIFICATION_TTL_MS`), at most 5 verify attempts per row
// before it's invalidated. The plaintext code is never persisted — we
// only keep its hash so a DB leak doesn't expose live OTPs.
model PhoneVerification {
  id         String    @id @default(cuid())
  userId     String
  phone      String
  codeHash   String
  expiresAt  DateTime
  attempts   Int       @default(0)
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("phone_verifications")
}

// SMS-based 2FA login challenge (ratchet 45, cycle 131).
//
// Holds the bcrypt-hashed 6-digit OTP issued by
// `POST /api/auth/2fa/sms/challenge`. Unlike `PhoneVerification` this
// row is meant for the LOGIN flow (so it can be issued without an
// authenticated session) and is keyed by an opaque `challengeId` that
// the client echoes back on `POST /api/auth/2fa/sms/verify`. Single-use,
// TTL 5 minutes (override with `TWOFA_SMS_TTL_MS`), at most 5 verify
// attempts per row before it's invalidated. The plaintext code is
// never persisted — we only keep its hash so a DB leak doesn't expose
// live OTPs. The `lookup` column stores a SHA-256 of the contact value
// (email or E.164 phone) so attacker-controlled enumeration of "does
// this email have 2FA?" still requires guessing the hash.
//
// Login-flow integration (binding to a partial session, gating the
// final JWT) is intentionally left for the next cycle — this model
// scaffolds the challenge lifecycle only.
model TwoFAChallenge {
  id          String    @id @default(cuid())
  challengeId String    @unique
  userId      String?
  channel     String // 'sms'  — leaves room for 'totp' / 'email' later
  destination String // E.164 phone or email used to deliver the OTP
  lookup      String // SHA-256 of normalized destination for safer indexing
  codeHash    String
  expiresAt   DateTime
  attempts    Int       @default(0)
  consumedAt  DateTime?
  createdAt   DateTime  @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([lookup])
  @@map("two_fa_challenges")
}

// Partial session bridge (ratchet 45, TOTP login gate).
//
// When the login handler determines the user must complete a TOTP
// challenge (totpEnabled = true and twoFactorEnabled = false), it
// mints a short-lived (5 minute) opaque token persisted here instead
// of issuing a full session JWT. The client echoes the token back to
// `POST /api/auth/2fa/totp/verify` together with the 6-digit code; on
// success the row is consumed and a real Session + JWT are minted.
//
// Single-use semantics: `consumedAt` is set the first time the token
// is redeemed and subsequent lookups are rejected. The expiresAt
// column lets a sweeper GC stale rows without a separate scheduler.
model PartialSession {
  id         String    @id @default(cuid())
  token      String    @unique
  userId     String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("partial_sessions")
}

model AgentCheckpoint {
  threadId           String   @map("thread_id")
  checkpointId       String   @map("checkpoint_id")
  parentCheckpointId String?  @map("parent_checkpoint_id")
  state              Json     @default("{}")
  metadata           Json     @default("{}")
  createdAt          DateTime @default(now()) @map("created_at")

  @@id([threadId, checkpointId])
  @@index([threadId, createdAt(sort: Desc)])
  @@map("agent_checkpoints")
}

model UserMemory {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  content         String   @db.Text
  category        String?
  importanceScore Float    @default(0) @map("importance_score")
  confidence      Float    @default(0.8) @map("confidence")
  lastAccessedAt  DateTime @default(now()) @map("last_accessed_at")
  accessCount     Int      @default(0) @map("access_count")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user       User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  embeddings UserMemoryEmbedding[]

  @@index([userId, category])
  @@index([userId, importanceScore(sort: Desc)])
  @@map("user_memories")
}

model UserMemoryEmbedding {
  id        String   @id @default(cuid())
  memoryId  String   @map("memory_id")
  embedding Bytes    @db.ByteA
  createdAt DateTime @default(now()) @map("created_at")

  memory UserMemory @relation(fields: [memoryId], references: [id], onDelete: Cascade)

  @@index([memoryId])
  @@map("user_memory_embeddings")
}

// ───────────────────────────────────────────────────────────────────────────
// Contabilidad (PCGE peruano · partida doble) — feat/contabilidad
// ───────────────────────────────────────────────────────────────────────────

/// Plan de cuentas jerárquico basado en el PCGE peruano.
model AccountingAccount {
  id         String   @id @default(cuid())
  code       String   @unique // código PCGE, p.ej. "10", "1011", "70"
  name       String
  element    Int // 1–9 (elemento/clase PCGE)
  level      Int // profundidad (1=elemento, 2=2 dígitos, …)
  parentCode String? // código PCGE del padre
  nature     String // DEUDORA | ACREEDORA (saldo normal)
  type       String // ACTIVO | PASIVO | PATRIMONIO | INGRESO | GASTO | COSTO | ORDEN
  postable   Boolean  @default(false) // sólo las cuentas de detalle (hoja) aceptan asientos
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  lines AccountingJournalLine[]

  @@index([element])
  @@index([parentCode])
  @@index([postable])
  @@map("accounting_accounts")
}

/// Asiento del libro diario (partida doble: Σ debe = Σ haber).
model AccountingJournalEntry {
  id           String   @id @default(cuid())
  number       Int      @unique // correlativo del diario
  date         DateTime
  glosa        String // descripción / glosa del asiento
  currency     String   @default("PEN") // PEN | USD
  exchangeRate Decimal? @db.Decimal(18, 6) // tipo de cambio cuando currency != PEN
  status       String   @default("POSTED") // DRAFT | POSTED | VOID
  source       String   @default("MANUAL") // MANUAL | SALE | PAYMENT | OPENING | CLOSING
  sourceId     String? // id del comprobante/cobro que originó el asiento
  periodId     String?
  userId       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  lines AccountingJournalLine[]

  @@index([date])
  @@index([status])
  @@index([source, sourceId])
  @@index([periodId])
  @@map("accounting_journal_entries")
}

/// Línea de un asiento (un cargo o abono sobre una cuenta).
model AccountingJournalLine {
  id          String   @id @default(cuid())
  entryId     String
  accountId   String
  accountCode String // desnormalizado para reportes rápidos
  debit       Decimal  @default(0) @db.Decimal(18, 2)
  credit      Decimal  @default(0) @db.Decimal(18, 2)
  description String?
  createdAt   DateTime @default(now())

  entry   AccountingJournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  account AccountingAccount      @relation(fields: [accountId], references: [id])

  @@index([entryId])
  @@index([accountId])
  @@index([accountCode])
  @@map("accounting_journal_lines")
}

/// Periodo contable mensual con apertura/cierre. Un periodo CERRADO bloquea
/// el alta de asientos cuya fecha caiga dentro de él.
model AccountingPeriod {
  id        String    @id @default(cuid())
  year      Int
  month     Int // 1–12
  startDate DateTime
  endDate   DateTime
  status    String    @default("OPEN") // OPEN | CLOSED
  closedAt  DateTime?
  closedBy  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([year, month])
  @@index([status])
  @@map("accounting_periods")
}

/// Tipo de cambio por fecha y moneda (rate = soles PEN por 1 unidad de la
/// moneda extranjera). SUNAT publica compra/venta; se guarda por rateType.
model AccountingExchangeRate {
  id        String   @id @default(cuid())
  date      DateTime
  currency  String // moneda extranjera, p.ej. "USD"
  rate      Decimal  @db.Decimal(18, 6)
  rateType  String   @default("VENTA") // COMPRA | VENTA
  source    String   @default("MANUAL") // MANUAL | SUNAT | SBS
  createdAt DateTime @default(now())

  @@unique([date, currency, rateType])
  @@index([currency, date])
  @@map("accounting_exchange_rates")
}

/// Cliente del módulo contable (para facturación/comprobantes).
model AccountingCustomer {
  id        String   @id @default(cuid())
  docType   String // RUC | DNI | CE | PASAPORTE | SIN_DOC
  docNumber String
  name      String
  email     String?
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([docType, docNumber])
  @@index([name])
  @@map("accounting_customers")
}

/// Catálogo de productos/servicios facturables, incluidas las suscripciones del SaaS.
model AccountingProduct {
  id             String   @id @default(cuid())
  code           String   @unique
  name           String
  kind           String   @default("SERVICE") // SERVICE | GOOD
  unitPrice      Decimal  @default(0) @db.Decimal(18, 2)
  currency       String   @default("PEN") // PEN | USD
  unit           String   @default("NIU") // unidad de medida SUNAT
  igvAffected    Boolean  @default(true) // afecto a IGV (18%)
  isSubscription Boolean  @default(false) // suscripción del propio SaaS
  incomeAccount  String? // cuenta PCGE de ingreso (p.ej. 7011)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([kind])
  @@index([isSubscription])
  @@map("accounting_products")
}
