model DocumentTable {
  id          String   @id @default(cuid())
  analysisId  String
  fileId      String
  ordinal     Int
  sourceType  String
  sourceLabel String?
  pageNumber  Int?
  sheetName   String?
  slideNumber Int?
  title       String?
  columns     String[]
  rowCount    Int      @default(0)
  preview     Json?
  markdown    String?  @db.Text
  metadata    Json?
  createdAt   DateTime @default(now())

  analysis DocumentAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  file     File             @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([analysisId, ordinal])
  @@index([fileId, ordinal])
  @@map("document_tables")
}

// Hierarchical document nodes — tree structure (root → sections →
// subsections → paragraphs) with bottom-up summaries. Built by
// services/rag/hierarchical-chunker.js for queries that need
// either pinpoint recall or whole-document overview.
model DocumentNode {
  id         String   @id
  fileId     String
  analysisId String?
  parentId   String?
  level      Int
  role       String // 'root' | 'section' | 'paragraph' | …
  heading    String?
  text       String   @default("") @db.Text
  summary    String   @default("") @db.Text
  embedding  Json? // float[] stored as JSON for portability
  metadata   Json?
  ordinal    Int      @default(0)
  createdAt  DateTime @default(now())

  file     File              @relation(fields: [fileId], references: [id], onDelete: Cascade)
  analysis DocumentAnalysis? @relation(fields: [analysisId], references: [id], onDelete: SetNull)
  parent   DocumentNode?     @relation("DocumentNodeChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children DocumentNode[]    @relation("DocumentNodeChildren")

  @@index([fileId, ordinal])
  @@index([fileId, level])
  @@index([parentId])
  @@index([analysisId])
  @@map("document_nodes")
}

// Local Invoice mirror (spec §8). Webhook-fed copy of Stripe invoice
// objects so the billing UI can read history from Postgres instead of
// making a network call to Stripe on every page load. Source of truth
// remains Stripe; this table is eventually consistent via webhook fan-out.
//
// Amounts stored in cents (Int) to match Stripe's wire format and avoid
// the float drift Payment.amount suffers from.
enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  UNCOLLECTIBLE
  VOID
}

model Invoice {
  id                   String        @id @default(cuid())
  userId               String
  stripeInvoiceId      String        @unique
  stripeCustomerId     String?
  stripeSubscriptionId String?
  number               String?
  status               InvoiceStatus @default(OPEN)
  amountDueCents       Int           @default(0)
  amountPaidCents      Int           @default(0)
  amountRemainingCents Int           @default(0)
  subtotalCents        Int           @default(0)
  totalCents           Int           @default(0)
  currency             String        @default("usd")
  periodStart          DateTime?
  periodEnd            DateTime?
  hostedInvoiceUrl     String?
  invoicePdfUrl        String?
  lines                Json?
  issuedAt             DateTime?
  paidAt               DateTime?
  dueDate              DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([stripeSubscriptionId])
  @@map("invoices")
}

model Payment {
  id         String          @id @default(cuid())
  userId     String
  amount     Float
  currency   String          @default("USD")
  status     PaymentStatus   @default(PENDING)
  plan       Plan
  provider   PaymentProvider
  providerId String? // External payment ID (Stripe session ID, PayPal order ID, etc.)

  // Stripe specific fields
  stripeSessionId      String? @unique
  stripeSubscriptionId String?
  stripeCustomerId     String?
  stripePriceId        String?

  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@map("payments")
}

model ApiUsage {
  id        String   @id @default(cuid())
  userId    String
  model     String
  tokens    BigInt
  cost      Float
  timestamp DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, timestamp])
  @@index([model, timestamp])
  @@map("api_usage")
}

model SystemSettings {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text

  @@map("system_settings")
}

// Ratchet 45 — daily aggregate of AI cost usage.
//
// The in-process cost-tracker flushes once a day (05:00 UTC by default)
// into this table so historical reports survive process restarts. Rows
// are aggregated by (date, userId, model, provider, organizationId) —
// the unique compound key — and upserted, so a partial flush followed by
// a retry never double-counts.
model CostUsageDaily {
  id             String   @id @default(cuid())
  userId         String   @default("")
  organizationId String   @default("")
  date           DateTime @db.Date
  model          String
  provider       String   @default("")
  inputTokens    BigInt   @default(0)
  outputTokens   BigInt   @default(0)
  costUSD        Float    @default(0)
  requests       Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([date, userId, model, provider, organizationId], name: "cost_usage_daily_unique")
  @@index([date])
  @@index([userId, date])
  @@index([organizationId, date])
  @@map("cost_usage_daily")
}

// F1 — Plans catalog. Distinct from the `Plan` enum (kept for back-compat
// of `User.plan` / `Payment.plan`). `code` is the natural key joining the
// two: `PlanCatalog.code` == `Plan` enum value. F2 introduces `User.planId`
// FK referencing this table; for now both coexist.
model PlanCatalog {
  id                   String   @id @default(cuid())
  code                 String   @unique
  name                 String
  description          String?
  priceMonthlyCents    Int      @default(0)
  priceYearlyCents     Int      @default(0)
  currency             String   @default("usd")
  monthlyCredits       BigInt   @default(0)
  trialDays            Int      @default(0)
  features             Json     @default("[]")
  stripePriceIdMonthly String?
  stripePriceIdYearly  String?
  isActive             Boolean  @default(true)
  displayOrder         Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @default(now()) @updatedAt

  @@index([isActive, displayOrder])
  @@map("plans")
}

// F1 PR2 — Declarative RBAC. `roles` are named buckets; `permissions`
// are `resource.action` codes; `role_permissions` maps roles to
// permissions; `user_roles` assigns roles to users (optionally scoped
// to an organization). The legacy `OrgRole` enum is kept for back-compat
// on `OrgMembership.role`; PR4 backfills `user_roles` from it.
model Role {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  permissions RolePermission[]
  userRoles   UserRole[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(cuid())
  code        String   @unique
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(cuid())
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

enum RoleScope {
  GLOBAL
  ORG
}

model UserRole {
  id         String    @id @default(cuid())
  userId     String
  roleId     String
  scope      RoleScope @default(GLOBAL)
  scopeId    String?
  assignedBy String?
  assignedAt DateTime  @default(now())

  user     User  @relation("UserRoleAssignedTo", fields: [userId], references: [id], onDelete: Cascade)
  role     Role  @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assigner User? @relation("UserRoleAssignedBy", fields: [assignedBy], references: [id], onDelete: SetNull)

  @@index([userId, scope])
  @@index([roleId])
  @@map("user_roles")
}

enum ProviderType {
  OpenAI
  Gemini
  OpenRouter
  DeepSeek
  Groq
  Custom // Mustaqbil ke liye
}

enum ModelType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  MUSIC
}

