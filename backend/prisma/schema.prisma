// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String  @id @default(cuid())
  email            String  @unique
  name             String
  password         String
  avatar           String?
  googleId         String? @unique
  plan             Plan    @default(FREE)
  isAdmin          Boolean @default(false)
  isSuperAdmin     Boolean @default(false) // Super admin can impersonate any user
  apiUsage         BigInt  @default(0)
  gemaTokenUsage   BigInt  @default(0)
  gemaTokenLimit   BigInt  @default(0)
  monthlyCallLimit BigInt  @default(3) // NEW: counts number of generate calls / month
  monthlyLimit     BigInt  @default(1000)

  // Gmail Integration
  gmailTokens String? // Store encrypted Gmail OAuth tokens as JSON

  // Google Services Integration (Calendar & Drive)
  googleServicesTokens String? // Store encrypted Google OAuth tokens for Calendar & Drive as JSON

  // Spotify Integration
  spotifyTokens String? // Store encrypted Spotify OAuth tokens as JSON

  // Stripe Integration Fields
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  subscriptionStatus   String? // active, inactive, canceled, past_due
  subscriptionEndDate  DateTime?

  // Personalization — injected into the master system prompt per turn so
  // every LLM call hears the user's voice (not just their chat history).
  locale             String? // ISO 639-1, e.g. "es", "en". Null → auto-detect from message.
  preferredTone      String? // e.g. "casual", "formal", "technical", "pedagogical"
  customInstructions String? @db.Text // free-form "what should the assistant know about you"

  // Flexible settings bag — stores the full settings tree from /settings
  // (theme, accent, density, font size, notification prefs, app toggles,
  // etc.). JSON lets us evolve the shape without migrations. Controls
  // that need to be queryable (locale, tone) live in their own columns.
  settings Json?

  // Last activity timestamp — written via the write-behind cache from
  // every authenticated request. Used by /api/admin/stats/users to
  // distinguish active vs dormant accounts. Nullable so existing rows
  // are unaffected by the migration.
  lastActiveAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // GDPR soft-delete tombstone. When non-null the account is in the
  // 30-day grace window before the hard-delete cron purges it.
  deletedAt DateTime?

  // Email verification — non-null once the user has clicked the
  // magic link from `EmailVerificationToken`. Org invitations (cycle
  // 27) gate full membership acceptance on this column being set so
  // a freshly-invited stranger can't slip past identity checks.
  emailVerifiedAt DateTime?

  // SMS opt-in — E.164 phone number used by the SMS-delivery bridge
  // (ratchet 45) to fan out `severity === 'critical'` notifications
  // through Twilio. Nullable: users without a phone simply skip SMS.
  phone String?

  // Phone verification — non-null once the user has redeemed a 6-digit
  // SMS code issued by `PUT /api/users/me/phone` and accepted by
  // `POST /api/users/me/phone/verify` (ratchet 45, Task 1).
  phoneVerifiedAt DateTime?

  // SMS 2FA opt-in flag — when true AND phoneVerifiedAt is non-null, the
  // /api/auth/login handler returns a 202 partial-session response that
  // forces the user through /api/auth/2fa/sms/verify before a full JWT is
  // issued (ratchet 45, 2FA opt-in cycle). Defaults to false so legacy
  // users retain the cycle-0 login behaviour until they opt in via
  // `PATCH /api/users/me/2fa`.
  twoFactorEnabled Boolean @default(false)

  // TOTP-based 2FA (ratchet 45, Task 1) — alternative to SMS for
  // Google Authenticator / Authy / 1Password etc. `totpSecret` holds
  // the base32 seed encrypted at rest with the platform ENCRYPTION_KEY
  // (see src/utils/encryption.js). When `totpEnabled` is true the login
  // handler accepts a 6-digit TOTP code in addition to (or instead of)
  // an SMS challenge. Both columns are nullable / default-off so legacy
  // rows keep working.
  totpSecret        String?
  totpEnabled       Boolean @default(false)
  // Ratchet 45 — TOTP recovery codes (Task 2). 10 single-use 16-char
  // codes are generated when the user calls
  // POST /api/users/me/2fa/totp/recovery-codes (totpEnabled required).
  // Stored hashed as `[{ hash, usedAt? }]`; the plaintext is returned
  // ONCE at generation time. Recovery codes are accepted as an
  // alternative to the 6-digit code at POST /api/auth/2fa/totp/verify.
  totpRecoveryCodes Json?

  // Ratchet 45 — WebAuthn / passkey credentials (scaffold follow-up
  // to the cycle 135 TOTP rollout). JSON array of
  // `{ credentialId, publicKey, counter, transports[], label?,
  //   createdAt, lastUsedAt? }`. credentialId + publicKey are
  // base64url. Managed via the four endpoints under
  // /api/users/me/webauthn/* (registration) and
  // /api/auth/webauthn/* (authentication). See
  // backend/src/services/webauthn.js. Null on legacy rows.
  webauthnCredentials Json?

  // Relations
  chats                   Chat[]
  chatRuns                ChatRun[]
  payments                Payment[]
  invoices                Invoice[]
  apiUsages               ApiUsage[]
  sessions                Session[]
  files                   File[]
  createdGpts             CustomGpt[]
  projects                Project[]
  designs                 DesignProject[]
  scheduledPosts          ScheduledPost[]
  socialConnections       SocialConnection[]
  searchBrainSettings     SearchBrainSettings?
  usageAlerts             UsageAlert[]
  notifications           Notification[]
  subscriptionEvents      SubscriptionEvent[]
  agentTasks              AgentTask[]
  goalRuns                GoalRun[]
  codexProjects           CodexProject[]
  codexRuns               CodexRun[]
  generatedArtifacts      GeneratedArtifact[]
  documentAnalyses        DocumentAnalysis[]
  pushSubscriptions       PushSubscription[]
  savedSearches           SavedSearch[]
  bookmarks               Bookmark[]
  webhookEndpoints        WebhookEndpoint[]
  slackIntegrations       SlackIntegration[]
  policyAcceptances       PolicyAcceptance[]
  apiKeys                 ApiKey[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  phoneVerifications      PhoneVerification[]
  twoFAChallenges         TwoFAChallenge[]
  partialSessions         PartialSession[]

  // Organization / team membership — multi-tenant scaffolding (cycle 27).
  // A user can belong to multiple organizations with different roles.
  // `ownedOrganizations` covers the legacy "creator" pointer on the org
  // row; `organizationMemberships` is the source of truth for ACL.
  ownedOrganizations      Organization[]        @relation("OrganizationOwner")
  organizationMemberships OrgMembership[]
  sentOrgInvitations      OrgInvitation[]       @relation("OrgInvitationInviter")
  createdOrgAnnouncements OrgAnnouncement[]     @relation("OrgAnnouncementCreator")
  announcementReads       OrgAnnouncementRead[]
  pendingTransfersFrom    OrgPendingTransfer[]  @relation("OrgPendingTransferFrom")
  pendingTransfersTo      OrgPendingTransfer[]  @relation("OrgPendingTransferTo")

  // User memory relations (orchestration)
  memories UserMemory[]

  // Agent harness — external MCP servers registered by this user.
  mcpServers McpServer[]

  // F1 — declarative RBAC. `userRoles` joins to `user_roles` and
  // ultimately to `roles` + `permissions`. The legacy `isSuperAdmin`
  // flag stays as a shadow until F5 sunset.
  userRoles     UserRole[] @relation("UserRoleAssignedTo")
  assignedRoles UserRole[] @relation("UserRoleAssignedBy")

  @@index([deletedAt])
  @@map("users")
}

model PushSubscription {
  id         String   @id @default(cuid())
  userId     String
  token      String   @unique
  platform   String // 'ios' | 'android' | 'web'
  endpoint   String?
  p256dh     String?
  auth       String?
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

model AiModel {
  id          String    @id @default(cuid())
  name        String    @unique
  displayName String
  provider    String
  description String?
  apiKey      String?
  type        ModelType @default(TEXT) // <-- NAYA: Model ki type (TEXT/IMAGE)
  icon        String?
  isActive    Boolean   @default(false)

  // Auto-sync tracking fields
  lastSynced    DateTime?
  syncSource    String?   @default("manual") // "api", "manual", "scheduled"
  contextLength Int? // Model's context window size
  pricing       Json? // Provider pricing information
  tags          String[] // Model tags/categories

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ai_models")
}

// Admin-curated upstream API connections used to source AI models.
// Each row is one base URL + auth combo (e.g. https://api.openai.com/v1
// with a specific key). The /admin/models view enumerates models
// surfaced by these connections; chat code routes a model request
// through the connection that exposes it.
//
// `apiKey` is stored as-is for MVP — a future migration will swap
// the column for an envelope-encrypted blob keyed by a master KEK.
model AdminConnection {
  id            String    @id @default(cuid())
  url           String // base URL, e.g. https://api.openai.com/v1
  providerKey   String // "openai" | "anthropic" | "gemini" | "mistral" | "groq" | "openrouter" | "custom"
  providerLabel String? // human label, e.g. "OpenAI API"
  apiKey        String? // bearer token; null = no auth (e.g. local Ollama)
  authType      String    @default("Bearer") // "Bearer" | "None" | "Custom"
  apiType       String    @default("chat_completions") // "chat_completions" | "responses" | "embeddings"
  headers       Json? // optional extra request headers
  prefixId      String? // model name prefix for namespacing
  modelIds      String[] // empty array = include all from /models endpoint
  tags          String[]
  enabled       Boolean   @default(true)
  // Per-connection sync status (last list-models call)
  lastSyncedAt  DateTime?
  lastSyncOk    Boolean   @default(false)
  lastSyncError String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([providerKey])
  @@index([enabled])
  @@map("admin_connections")
}

model Session {
  id          String    @id @default(cuid())
  userId      String
  token       String    @unique
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  // lastUsedAt: bumped by routes that re-use a long-lived session (e.g.
  // /api/appshots/capture) so the settings UI can show "last seen" and
  // the user can confidently revoke stale Appshots tokens. Nullable so
  // pre-migration rows don't have to backfill.
  lastUsedAt  DateTime?
  // fingerprint: hex sha256(IP-class || User-Agent) recorded at login,
  // compared on each request so a leaked token can't be replayed from
  // a different network or browser. See utils/session-fingerprint.js.
  fingerprint String?
  // Task 15 — Appshots device hints. Recorded at /api/appshots/pair so the
  // settings UI can distinguish multiple linked devices ("Chrome en macOS ·
  // 81.x.x.x"). All nullable: cookie sessions and pre-migration rows leave
  // them empty. ipHint is the /24 (IPv4) or /64 (IPv6) network prefix from
  // reduceIp() — never the full address — to avoid leaking precise IPs
  // back to the UI. label is a user-editable nickname.
  userAgent   String?
  ipHint      String?
  label       String?
  // Task 19 — human-readable geo hint resolved from the caller's IP at
  // pair time (e.g. "Madrid, ES"). Best-effort: NULL when the lookup
  // fails, when the IP is private/reserved, or for pre-migration rows.
  // The UI shows it alongside (or in place of) ipHint to make the
  // session list legible at a glance.
  geoHint     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model Chat {
  id        String   @id @default(cuid())
  userId    String
  title     String
  model     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  isShared Boolean @default(false)
  shareId  String? @unique

  // Lifecycle flags driven from the Settings → Data controls section.
  // `isArchived` hides the chat from the main list without deleting it;
  // `deletedAt` soft-deletes with a 30-day window before hard purge.
  isArchived Boolean   @default(false)
  deletedAt  DateTime?

  // Pinned-chat support (Sprint 6 sidebar UX). pinnedAt is null when
  // the chat is unpinned so the sidebar can sort pinned items by the
  // time the user pinned them.
  isPinned Boolean   @default(false)
  pinnedAt DateTime?

  // Per-chat draft text the composer auto-saves so the user can "keep
  // writing where they left off" after navigating away. Stored
  // server-side (in addition to the client localStorage mirror) so the
  // draft survives across devices.
  draftText String? @db.Text

  // Language policy — persisted resolution of "what language should the
  // assistant reply in for this thread". Set on first turn (or on any
  // explicit "respond in X" instruction); reused on every subsequent turn
  // so short follow-ups like "ok", "continúa", "summarize" don't drift to
  // the model's default language. ISO 639-1 (es, en, pt, fr, …).
  preferredResponseLanguage String?

  googleCalendarContext Json? // NEW: Store recent Google Calendar event IDs for context

  // Word Connector Integration
  isWordConnectorChat Boolean @default(false) // Track if this chat is for Word Connector
  wordContent         String? @db.Text // Store the full Word document HTML content

  // Excel Connector Integration
  isExcelConnectorChat Boolean @default(false) // Track if this chat is for Excel Connector
  excelContent         Json? // Store the workbook JSON (Syncfusion openFromJson compatible)

  // GPT Integration
  customGptId String?
  customGpt   CustomGpt? @relation(fields: [customGptId], references: [id], onDelete: SetNull)

  // Project Integration — mirrors customGptId. When set, the AI route
  // injects the project's instructions + attached file contents into
  // the system prompt so a chat inside a project answers with that
  // context baked in.
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  // Organization sharing (cycle 27). When non-null, members of the
  // organization with at least VIEWER role can see this chat. The
  // chat owner remains `userId`; sharing does not transfer ownership.
  organizationId String?
  sharedAt       DateTime?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  // Relations
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages           Message[]
  sharedMessages     MessageShare[]      @relation("SharedMessages")
  agentTasks         AgentTask[]
  goalRuns           GoalRun[]
  generatedArtifacts GeneratedArtifact[]
  runs               ChatRun[]

  @@index([userId, updatedAt])
  @@index([customGptId])
  @@index([projectId])
  @@index([organizationId, sharedAt])
  @@index([userId, isPinned, pinnedAt])
  @@map("chats")
}

model Message {
  id        String      @id @default(cuid())
  chatId    String
  role      MessageRole
  content   String      @db.Text
  tokens    BigInt?
  timestamp DateTime    @default(now())
  files     Json? // Store file references
  metadata  Json? // Store message metadata (like Gmail connection requirements)
  feedback  String?

  // Claude-style extended thinking. `reasoning` is the human-readable
  // chain-of-thought streamed by reasoning models (OpenRouter `reasoning`,
  // DeepSeek `reasoning_content`); `reasoningDetails` is the RAW OpenRouter
  // `reasoning_details` array, persisted verbatim because Anthropic models
  // require it replayed intact on later tool-call turns (signed thinking
  // chain). Assistant rows only; null elsewhere.
  reasoning        String? @db.Text
  reasoningDetails Json?   @map("reasoning_details")

  // Agent harness (Phase 1): compact projection of the agent run that
  // produced this assistant message — status, totals and per-step previews
  // so chat history re-renders the collapsed AgentTrace without joining
  // agent_steps. The full-fidelity trace lives in the AgentStep relation.
  agentMetadata Json? @map("agent_metadata")

  // Soft-delete tombstone — mirrors Chat.deletedAt so GDPR delete can
  // cascade without losing chat shape (foreign-key cascade still works
  // on hard purge from the cron).
  deletedAt DateTime?

  // Full-text search tsvector — managed by a Postgres trigger on
  // INSERT/UPDATE OF content (see migration
  // 20260519040000_add_message_fts). Declared as Unsupported because
  // Prisma's Postgres connector doesn't have a first-class tsvector
  // type — we never read/write it from the JS client, only via raw
  // SQL in /api/search.
  content_tsv Unsupported("tsvector")?

  // Link to the ChatRun that produced this message (assistant rows only).
  // Null on user rows and on legacy assistant rows that pre-date the
  // ChatRun introduction.
  runId String?

  // Relations
  chat               Chat                @relation(fields: [chatId], references: [id], onDelete: Cascade)
  generatedArtifacts GeneratedArtifact[]
  bookmarks          Bookmark[]
  run                ChatRun?            @relation("RunMessage", fields: [runId], references: [id], onDelete: SetNull)
  agentSteps         AgentStep[]

  @@index([chatId, timestamp])
  @@index([chatId, deletedAt])
  @@index([runId])
  @@map("messages")
}

// ────────────────────────────────────────────────────────────
// AgentStep — full-fidelity trace of one agent-harness step (a reasoning
// burst or a tool call) for the assistant message it produced. Streamed
// live over SSE during the turn; persisted here after the message row
// exists so history re-renders complete AgentTrace timelines. Results are
// capped at 30k chars (explicit truncation marker) by the event stream.
model AgentStep {
  id         String   @id @default(cuid())
  messageId  String   @map("message_id")
  stepIndex  Int      @map("step_index")
  type       String // 'tool_call' | 'reasoning'
  toolName   String?  @map("tool_name")
  args       Json?
  result     Json?
  status     String   @default("completed") // completed | error | denied | interrupted | running
  durationMs Int?     @map("duration_ms")
  isError    Boolean  @default(false) @map("is_error")
  createdAt  DateTime @default(now()) @map("created_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId, stepIndex])
  @@map("agent_steps")
}

// ────────────────────────────────────────────────────────────
// McpServer — a user-registered EXTERNAL MCP server (Model Context
// Protocol) whose tools are discovered at the start of an agent turn and
// merged into the chat toolset as mcp__<server>__<tool> with permission
// tier 'confirm'. `headersEncrypted` holds the AES-256-CBC encrypted JSON
// of auth headers (utils/encryption) — never returned by the API.
model McpServer {
  id               String   @id @default(cuid())
  userId           String   @map("user_id")
  name             String
  url              String
  transport        String   @default("streamable-http") // streamable-http | sse
  headersEncrypted String?  @map("headers_encrypted") @db.Text
  enabled          Boolean  @default(true)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId, enabled])
  @@map("mcp_servers")
}

// ────────────────────────────────────────────────────────────
// ChatRun — durable record of one AI generation. The HTTP route
// enqueues a row + a BullMQ job; the worker reads it, streams the
// answer, and writes the final content back to the linked Message.
// This is the source of truth for "is this chat still generating in
// background", "what is its partial text" and "did it complete on a
// previous server boot."
// ────────────────────────────────────────────────────────────
enum ChatRunStatus {
  pending
  running
  completed
  failed
  cancelled
}

model ChatRun {
  id              String        @id @default(cuid())
  chatId          String
  userId          String
  status          ChatRunStatus @default(pending)
  model           String
  provider        String?
  promptMessageId String?
  // The assistant Message row this run is producing into. Created up
  // front with empty content so the UI can stream into a stable id.
  messageId       String?       @unique
  partialContent  String        @default("") @db.Text
  inputPayload    Json
  error           String?
  errorClass      String?
  jobId           String?
  startedAt       DateTime?
  lastChunkAt     DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  cancelReason    String?
  attempt         Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  chat    Chat      @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  message Message[] @relation("RunMessage")

  @@index([chatId, status])
  @@index([userId, status, updatedAt])
  @@index([status, createdAt])
  @@map("chat_runs")
}

// Saved searches — see migration 20260519050000_add_saved_search.
// `filters` is a free-form JSON bag (chatId, dateRange, role, etc.)
// so the search panel can grow new knobs without a migration.
model SavedSearch {
  id        String   @id @default(cuid())
  userId    String
  name      String
  query     String
  filters   Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("saved_searches")
}

// Bookmarks — per-user favourites on individual messages. The
// optional `note` field is a user-authored annotation. Unique on
// (userId, messageId) prevents duplicate stars.
model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  messageId String
  note      String?
  // Optional grouping label so the UI can render bookmarks into
  // user-defined folders ("Prompts", "Bugs", …). Free-form string —
  // no FK to a folders table, so renaming is just an UPDATE and
  // there's no orphan cleanup. NULL means "uncategorised".
  folder    String?
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([userId, messageId])
  @@index([userId, createdAt])
  @@index([userId, folder])
  @@map("bookmarks")
}

// User-managed outbound webhook subscriptions. Each row is one
// {url, events[], secret} triple that the trigger registry fans out
// to when a matching event is published. The secret is the HMAC key
// the recipient uses to verify the signature header.
model WebhookEndpoint {
  id                      String    @id @default(cuid())
  userId                  String
  // Optional org scope. When set, this endpoint participates in org-level
  // fan-out (publish payloads carrying `orgId`). userId still records the
  // creator for audit / quota attribution. Cycle 45 added per-org webhooks.
  organizationId          String?
  url                     String
  events                  String[]
  secret                  String
  // Ratchet 45 (Task 1): rotate-secret grace window. When an operator
  // rotates the HMAC secret, the prior value is parked here until
  // `previousSecretExpiresAt` so downstream consumers have a window to
  // roll their stored secret without dropped deliveries. Both fields
  // are cleared on the next rotation (or by GC sweeping expired rows).
  previousSecret          String?
  previousSecretExpiresAt DateTime?
  // Ratchet 44 (Task 1): per-endpoint retry policy override. When null
  // the dispatcher falls back to its default (3 retries). Stored as
  // nullable so existing rows keep the default without backfill.
  maxRetries              Int?
  // Ratchet 44 (Task 2): optional delivery filters. Shape:
  //   { events?: string[], excludeUsers?: string[] }
  // - `events`        : include-list of event names (in addition to the
  //                     `events` glob array). When present an event must
  //                     appear here OR match a `events[]` glob to be
  //                     delivered.
  // - `excludeUsers`  : userIds whose publish() calls are silently
  //                     dropped for this endpoint (per-recipient mute).
  // Anything else in the JSON is ignored — the field is intentionally
  // forward-compatible.
  filters                 Json?
  isActive                Boolean   @default(true)
  createdAt               DateTime  @default(now())
  lastDeliveryAt          DateTime?

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, isActive])
  @@index([organizationId, isActive])
  @@map("webhook_endpoints")
}

// Per-user Slack Incoming Webhook configuration. The webhookUrl is
// encrypted at rest (AES-256-GCM, see services/slack-integration.js).
// `isEnabled` gates whether trigger-registry fires Slack notifications
// for this user — flipped off after the test ping until the user opts
// in explicitly.
model SlackIntegration {
  id             String    @id @default(cuid())
  userId         String
  organizationId String?
  webhookUrl     String    @db.Text
  channelName    String?
  isEnabled      Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  lastEventAt    DateTime?

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([organizationId, isEnabled])
  @@map("slack_integrations")
}

model AgentTask {
  id             String    @id @default(cuid())
  userId         String
  chatId         String?
  jobId          String?   @unique
  status         String    @default("queued")
  goal           String    @db.Text
  model          String?
  traceId        String?
  documentPolicy Json?
  state          Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  completedAt    DateTime?
  cancelledAt    DateTime?
  failedAt       DateTime?

  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  chat      Chat?               @relation(fields: [chatId], references: [id], onDelete: SetNull)
  events    AgentTaskEvent[]
  artifacts GeneratedArtifact[]

  @@index([userId, updatedAt])
  @@index([status, updatedAt])
  @@index([chatId])
  @@map("agent_tasks")
}

model AgentTaskEvent {
  id        String   @id @default(cuid())
  taskId    String
  seq       Int
  type      String
  payload   Json
  createdAt DateTime @default(now())

  task AgentTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, seq])
  @@index([taskId, createdAt])
  @@map("agent_task_events")
}

// Persistent /goal background runs. Mirrors the AgentTask + AgentTaskEvent
// shape: the parent row tracks status/counters/final report, and the
// child event log replays the SSE timeline so the chat composer can
// re-attach after a reload without losing context. `agentKind` is a
// forward-looking discriminator (research today; code / image / video /
// song planned) so the same queue can drive multiple slash commands.
model GoalRun {
  id            String    @id @default(cuid())
  userId        String
  chatId        String?
  jobId         String?   @unique
  status        String    @default("queued")
  prompt        String    @db.Text
  depth         String    @default("standard")
  agentKind     String    @default("research")
  papersCount   Int       @default(0)
  findingsCount Int       @default(0)
  pagesCount    Int       @default(0)
  phase         String?
  finalReport   String?   @db.Text
  error         String?   @db.Text
  cancelReason  String?
  createdAt     DateTime  @default(now())
  startedAt     DateTime?
  updatedAt     DateTime  @updatedAt
  completedAt   DateTime?
  cancelledAt   DateTime?
  failedAt      DateTime?

  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  chat   Chat?          @relation(fields: [chatId], references: [id], onDelete: SetNull)
  events GoalRunEvent[]

  @@index([userId, status, updatedAt])
  @@index([chatId, status])
  @@index([status, createdAt])
  @@map("goal_runs")
}

model GoalRunEvent {
  id        String   @id @default(cuid())
  goalRunId String
  seq       Int
  type      String
  payload   Json
  createdAt DateTime @default(now())

  goalRun GoalRun @relation(fields: [goalRunId], references: [id], onDelete: Cascade)

  @@unique([goalRunId, seq])
  @@index([goalRunId, createdAt])
  @@map("goal_run_events")
}

model GeneratedArtifact {
