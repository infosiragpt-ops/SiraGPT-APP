# SiraGPT sandbox microservice — environment.
# The real .env lives ONLY on the sandbox host (never committed). The deploy
# script generates a strong SANDBOX_API_KEY into it + into ~/secrets.

# Bind to loopback only — public access is exclusively via the Cloudflare Tunnel.
SANDBOX_BIND=127.0.0.1
SANDBOX_PORT=4000

# Strong random key required to start (the service refuses to run without it).
# The MAIN APP must send the SAME value as `Authorization: Bearer <key>`.
SANDBOX_API_KEY=

# Capacity: with 32 vCPU, 15 simultaneous containers (1 vCPU each) is safe.
SANDBOX_MAX_CONCURRENCY=15
SANDBOX_SESSION_TTL_MS=600000

# Per-container limits (every ephemeral runner).
SANDBOX_RUNNER_IMAGE=siragpt-doc-sandbox:latest
SANDBOX_MEMORY=1g
SANDBOX_CPUS=1
SANDBOX_PIDS_LIMIT=100
SANDBOX_CMD_TIMEOUT_MS=120000
